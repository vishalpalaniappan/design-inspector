{
    "title": "Scripting Layout",
    "layoutRoot": "root",
    "containers": {
        "root": {
            "id": "root",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "menuBar",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 37, "unit": "px", "type": "fixed" }
                    }
                },
                {
                    "containerId": "bodyHorizontalSplit",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "containerId": "footer",
                    "type": "container",
                    "size": { "initial": { "value": 25, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 400, "condition": "lessThan", "relative": "parent" }
                }
            ]
        },
        "header": {
            "id": "header",
            "background": "#3c3c3c"
        },
        "bodyHorizontalSplit": {
            "id": "bodyHorizontalSplit",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "sidebar",
                    "type": "container",
                    "size": { "initial": { "value": 40, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 400, "condition": "lessThan", "relative": "parent" }
                },
                {
                    "containerId": "bodyVerticalSplit",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "bodyVerticalSplit": {
            "id": "bodyVerticalSplit",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "mainBody",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "mainBody",
                    "sibling2": "terminalContainer"
                },
                {
                    "containerId": "terminalContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 200, "unit": "px", "type": "fixed" },
                        "min": { "value": 100, "unit": "px"}
                    },
                    "collapse": { "value": 500, "condition": "lessThan", "relative": "parent" }
                }
            ]
            
        },
        "mainBody": {
            "id": "mainBody",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "designLayoutContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 500, "unit": "px", "type": "fixed" },
                        "min": { "value": 50, "unit": "px"}
                    }
                },
                {
                    "type": "handleBar",
                    "sibling1": "designLayoutContainer",
                    "sibling2": "contentContainer"
                },

                {
                    "containerId": "contentContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 500, "unit": "px", "type": "fixed" },
                        "min": { "value": 50, "unit": "px"}
                    }
                },
                {
                    "type": "handleBar",
                    "sibling1": "contentContainer",
                    "sibling2": "primitivesContainer"
                },
                
                {
                    "containerId": "primitivesContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "primitivesContainer",
                    "sibling2": "transformOutputMetadataContainer"
                },
                {
                    "containerId": "transformOutputMetadataContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "contentContainer": {
            "id": "contentContainer",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "body",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "body",
                    "sibling2": "transformationLogContainer"
                },
                {
                    "containerId": "transformationLogContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 300, "unit": "px", "type": "fixed" },
                        "min": { "value": 50, "unit": "px"}
                    }
                }
            ]
        },
        "designLayoutContainer": {
            "id": "designLayoutContainer",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "toolbarContainer",
                    "type": "container",
                    "size": { "initial": { "value": 40, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 100, "condition": "lessThan", "relative": "parent" }
                },
                {
                    "containerId": "FlowVerticalContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ],
            "background": "#1e1e1e"
        },
        "FlowVerticalContainer": {
            "id": "FlowVerticalContainer",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "FlowContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}

                },
                {
                    "containerId": "graphMenuContainer",
                    "type": "container",
                    "size": { "initial": { "value": 30, "unit": "px", "type": "fixed" }}
                }
            ]
        },
        "transformationLogContainer": {
            "id": "transformationLogContainer",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "transformationOutput",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ],
            "background": "#252526"
        },
        "traceViewer": {
            "id": "traceViewer",
            "component":"TraceSelector",
            "background": "#252526"
        },
        "terminalContainer": {
            "id": "terminalContainer",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "terminal",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ],
            "background": "#252526"
        },
        "terminal": {
            "id": "terminal",
            "tabsBar": {
                "tabs": [
                    {
                        "name": "Terminal",
                        "component": "PtyTerminal"
                    }
                ],
                "showClose": true,
                "closeContainerId": "terminalContainer"
            },
            "background": "#252526"
        },
        "body": {
            "id": "body",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "content",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "content": {
            "id": "content",
            "background": "#007acc",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "topContent",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "topContent",
                    "sibling2": "bottomContent"
                },
                {
                    "containerId": "bottomContent",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "topContent": {
            "id": "topContent",
            "background": "#007acc",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "initialArgs",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "initialArgs",
                    "sibling2": "preWorldStateContainer"
                },
                {
                    "containerId": "preWorldStateContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "bottomContent": {
            "id": "bottomContent",
            "background": "#007acc",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "expectedPostWorldStateEditor",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "expectedPostWorldStateEditor",
                    "sibling2": "outputContainer"
                },
                {
                    "containerId": "outputContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        
        "transformOutputMetadataContainer": {
            "id": "transformOutputMetadataContainer",
            "background": "#252526",
            "component": "TransformOutputMeta",
            "menuBar": {
                "showClose": false,
                "title": "Transform Metadata"
            }
        },
        "menuBar": {
            "id": "menuBar",
            "component": "ScriptingToolBar",
            "background": "#4f3b55"
        },
        "footer": {
            "id": "footer",
            "component": "StatusBar",
            "background": "#007acc"
        },
        "sidebar": {
            "id": "sidebar",
            "component": "SideBarMenu",
            "background": "#333"
        },
        "initialArgs": {
            "id": "initialArgs",
            "component": "InitialArgsEditor",
            "menuBar": {
                "showClose": false,
                "title": "Arguments"
            },
            "background": "#222222"
        },
        "preWorldStateContainer": {
            "id": "preWorldStateContainer",
            "component": "InitialWorldStateEditor",
            "menuBar": {
                "showClose": false,
                "title": "Initial World State"
            },
            "background": "#222222"
        },
        "expectedPostWorldStateEditor": {
            "id": "expectedPostWorldStateEditor",
            "component": "ExpectedPostWorldStateEditor",
            "menuBar": {
                "showClose": false,
                "title": "Expected Post Transformation World State"
            },
            "background": "#222222"
        },
        "outputContainer": {
            "id": "outputContainer",
            "component": "TransformationOutputViewer",
            "menuBar": {
                "showClose": false,
                "title": "Transformations Output"
            },
            "background": "#222222"
        },
        "primitivesContainer": {
            "id": "primitivesContainer",
            "component": "PrimitivesEditor",
            "menuBar": {
                "showClose": false,
                "title": "Behavioral Script"
            },
            "background": "#222222"
        },
        "transformationOutput": {
            "id": "transformationOutput",
            "component": "TransformationOutputLogViewer",
            "menuBar": {
                "showClose": false,
                "title": "Transformation Log"
            },
            "background": "#222222"
        },
        "selectedInfoContainer": {
            "id": "selectedInfoContainer",
            "component": "SelectedInfo",
            "background": "#1e1e1e"
        },
        "participantInfoContainer": {
            "id": "participantInfoContainer",
            "component": "NodeInfo",
            "background": "#1e1e1e"
        },
        "toolbarContainer": {
            "id": "toolbarContainer",
            "component": "ToolBar",
            "background": "#1e1e1e"
        },
        "FlowContainer": {
            "id": "FlowContainer",
            "component": "BehavioralControlGraph",
            "background": "#1e1e1e"
        },
        "graphMenuContainer": {
            "id": "graphMenuContainer",
            "component": "GraphMenuBar",
            "background": "#222222"
        }
    }
}