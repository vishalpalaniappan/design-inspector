{
    "title": "Scripting Layout",
    "layoutRoot": "root",
    "containers": {
        "root": {
            "id": "root",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "header",
                    "type": "container",
                    "size": { "initial": { "value": 0, "unit": "px", "type": "fixed" }}
                },
                {
                    "containerId": "mainBody",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "containerId": "footer",
                    "type": "container",
                    "size": { "initial": { "value": 25, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 400, "condition": "lessThan", "relative": "parent" }
                }
            ]
        },
        "header": {
            "id": "header",
            "background": "#3c3c3c"
        },
        "mainBody": {
            "id": "mainBody",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "sidebar",
                    "type": "container",
                    "size": { "initial": { "value": 40, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 400, "condition": "lessThan", "relative": "parent" }
                },
                {
                    "containerId": "contentContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "contentContainer",
                    "sibling2": "rightMenuContainer"
                },
                {
                    "containerId": "rightMenuContainer",
                    "type": "container",
                    "size": { "initial": { "value": 250, "unit": "px", "type": "fixed" }},
                    "collapse": { "value": 500, "condition": "lessThan", "relative": "parent" }
                }
            ]
        },
        "contentContainer": {
            "id": "contentContainer",
            "background": "#3c3c3c",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "menuBar",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 37, "unit": "px", "type": "fixed" }
                    }
                },
                {
                    "containerId": "body",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "body",
                    "sibling2": "transformationLogContainer"
                },
                {
                    "containerId": "transformationLogContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 150, "unit": "px", "type": "fixed" },
                        "min": { "value": 50, "unit": "px"}
                    }
                }
            ]
        },
        "transformationLogContainer": {
            "id": "transformationLogContainer",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "transformationOutput",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ],
            "background": "#252526"
        },
        "traceViewer": {
            "id": "traceViewer",
            "component":"TraceSelector",
            "background": "#252526"
        },
        "terminal": {
            "id": "terminal",
            "tabsBar": {
                "tabs": [
                    {
                        "name": "Terminal",
                        "component": "PtyTerminal"
                    }
                ],
                "showClose": true,
                "closeContainerId": "terminalContainer"
            },
            "background": "#252526"
        },
        "body": {
            "id": "body",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "content",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "content": {
            "id": "content",
            "background": "#007acc",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "topContent",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "topContent",
                    "sibling2": "bottomContent"
                },
                {
                    "containerId": "bottomContent",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "topContent": {
            "id": "topContent",
            "background": "#007acc",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "initialArgs",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 400, "unit": "px", "type": "fixed" }
                    }
                },
                {
                    "type": "handleBar",
                    "sibling1": "initialArgs",
                    "sibling2": "primitivesContainer"
                },
                {
                    "containerId": "primitivesContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "primitivesContainer",
                    "sibling2": "preWorldStateContainer"
                },
                {
                    "containerId": "preWorldStateContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "bottomContent": {
            "id": "bottomContent",
            "background": "#007acc",
            "type": "split",
            "orientation": "horizontal",
            "children": [
                {
                    "containerId": "expectedPostWorldStateEditor",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                },
                {
                    "type": "handleBar",
                    "sibling1": "expectedPostWorldStateEditor",
                    "sibling2": "outputContainer"
                },
                {
                    "containerId": "outputContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        
        "rightMenuContainer": {
            "id": "rightMenuContainer",
            "background": "#252526",
            "type": "split",
            "orientation": "vertical",
            "children": [
                {
                    "containerId": "selectedInfoContainer",
                    "type": "container",
                    "size": { 
                        "initial": { "value": 190, "unit": "px", "type": "fixed" }
                    }
                },
                {
                    "type": "handleBar",
                    "sibling1": "selectedInfoContainer",
                    "sibling2": "participantInfoContainer"
                },
                {
                    "containerId": "participantInfoContainer",
                    "type": "container",
                    "size": { "initial": { "type": "fill" }}
                }
            ]
        },
        "menuBar": {
            "id": "menuBar",
            "component": "ScriptingToolBar",
            "background": "#4f3b55"
        },
        "footer": {
            "id": "footer",
            "component": "StatusBar",
            "background": "#007acc"
        },
        "sidebar": {
            "id": "sidebar",
            "component": "SideBarMenu",
            "background": "#333"
        },
        "initialArgs": {
            "id": "initialArgs",
            "component": "InitialArgsEditor",
            "menuBar": {
                "showClose": false,
                "title": "Arguments"
            },
            "background": "#222222"
        },
        "preWorldStateContainer": {
            "id": "preWorldStateContainer",
            "component": "InitialWorldStateEditor",
            "menuBar": {
                "showClose": false,
                "title": "Initial World State"
            },
            "background": "#222222"
        },
        "expectedPostWorldStateEditor": {
            "id": "expectedPostWorldStateEditor",
            "component": "ExpectedPostWorldStateEditor",
            "menuBar": {
                "showClose": false,
                "title": "Expected Post Transformation World State"
            },
            "background": "#222222"
        },
        "outputContainer": {
            "id": "outputContainer",
            "component": "TransformationOutputViewer",
            "menuBar": {
                "showClose": false,
                "title": "Transformations Output"
            },
            "background": "#222222"
        },
        "primitivesContainer": {
            "id": "primitivesContainer",
            "component": "PrimitivesEditor",
            "menuBar": {
                "showClose": false,
                "title": "Primitive Transformations"
            },
            "background": "#222222"
        },
        "transformationOutput": {
            "id": "transformationOutput",
            "menuBar": {
                "showClose": false,
                "title": "Transformation Log"
            },
            "background": "#222222"
        },
        "selectedInfoContainer": {
            "id": "selectedInfoContainer",
            "component": "SelectedInfo",
            "background": "#1e1e1e"
        },
        "participantInfoContainer": {
            "id": "participantInfoContainer",
            "component": "NodeInfo",
            "background": "#1e1e1e"
        }
    }
}