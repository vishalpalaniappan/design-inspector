,"_name":"BookShelf","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToShelf","_description":""},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"5b1fe2b1-0c73-47e3-9cc2-43582cb8595d","type":5,"_behavior":{"dal_engine_uid":"b188ee5a-0266-442a-9366-63b5d3da8aa5","_type":1,"_participants":[{"dal_engine_uid":"1b30281f-0b91-4bf0-bae7-35efe0c7574b","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"FirstLetter","_description":"FirstLetterOfBooksName"}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GetFirstLetterOfBookName","_description":""},"_goToBehaviorIds":["AddBookToShelf","CreateSlotOnBookShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"93f857ee-8a19-440c-9348-014e34768859","type":5,"_behavior":{"dal_engine_uid":"00eaecb6-b8d9-4198-81ad-a225f106f54c","_type":1,"_participants":[{"dal_engine_uid":"5eb96c6c-d919-4393-b659-4f3c9c6f0d15","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Response","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAddBookToBasket","_description":""},"_goToBehaviorIds":["AcceptBook"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"ad5db342-4a7b-48fc-9408-ff8d05991f34","type":5,"_behavior":{"dal_engine_uid":"f4c73ebe-d887-4b18-a40d-601ff394dca2","_type":1,"_participants":[{"dal_engine_uid":"ffdab882-50e1-42d9-ae9e-5742ffe5329b","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Response","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAuditLibrary","_description":""},"_goToBehaviorIds":["GenerateAuditReport"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"b28fa95d-2793-44ef-906b-0aa1e92cb37b","type":5,"_behavior":{"dal_engine_uid":"422f5ab3-f62a-4f26-b859-6f0c7802705f","_type":1,"_participants":[{"dal_engine_uid":"1696bcf6-0d99-4bc1-8eee-6f8109731365","_type":3,"_invariants":[{"dal_engine_uid":"0d0b0881-b7b5-4ceb-84b3-d7b2c7bb501b","type":2,"invariantViolated":null,"invariantType":{"type":"min_length","label":"Minimum Length","properties":{"keys":{"label":"Key(s) of value in object","type":"Array","required":true,"value":["value","name"]},"minLength":{"label":"Minimum Length","type":"string","required":true,"value":"1"}},"invariantViolated":null},"traceId":null,"_name":"Book Name Length","_description":"Book name must have a minimum length of 1.","value":null}],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptBook","_description":"Accepts a book with a name and genre."},"_goToBehaviorIds":["PlaceBookInBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"461bb544-bf40-4ad0-902d-3bc19354dc0f","type":5,"_behavior":{"dal_engine_uid":"d43f941a-f4dc-4f85-9b3b-a8a59c880bfe","_type":1,"_participants":[{"dal_engine_uid":"57ec5c54-e0b5-486f-8041-45162b432ac3","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Basket","_description":""},{"dal_engine_uid":"26a17f69-c46b-4e70-9de1-e54022f577d1","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PlaceBookInBasket","_description":"Place book in basket."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"c9ff3bbe-330c-4a43-bda0-4f16ab5fdfcf","type":5,"_behavior":{"dal_engine_uid":"c2166025-5575-47ba-b940-321307a8a775","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GenerateAuditReport","_description":"Generate a report with all the books in the basket and all the books on the shelf."},"_goToBehaviorIds":["HandBookToUser"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"4cdd76aa-9a2b-4541-977d-c02fce29b2f5","type":5,"_behavior":{"dal_engine_uid":"22b47b48-051d-4bb4-b999-49327587ed9a","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"HandBookToUser","_description":"Give the report to the user."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false}],"name":"AcceptLoop","description":""}},"implementation":{"_sourceFiles":[{"name":"library_manager.py","path":"library_manager.py","content":"from typing import Optional, Dict, Any\r\n\r\n\r\n# Design world state\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef AcceptChoiceToPlaceBooksOnShelf(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to place books on the shelf.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptChoiceToAddBookToBasket(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to add a book to the basket.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n\r\n    Invariant:\r\n    - Book Name Length >= 1\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    # Invariant from design:\r\n    # Book Name Length\r\n    if len(book[\"name\"]) < 1:\r\n        raise ValueError(\"Invariant violated: Book name must have a minimum length of 1.\")\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef AcceptChoiceToAuditLibrary(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to audit the library.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    PresentMenuAndAcceptUserChoice\r\n      -> AcceptChoiceToPlaceBooksOnShelf\r\n      -> AcceptChoiceToAuditLibrary\r\n      -> AcceptChoiceToAddBookToBasket\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            AcceptChoiceToPlaceBooksOnShelf(response)\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            AcceptChoiceToAuditLibrary(response)\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            AcceptChoiceToAddBookToBasket(response)\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","updatedContent":"from typing import Optional, Dict, Any\r\n\r\n\r\n# Design world state\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef AcceptChoiceToPlaceBooksOnShelf(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to place books on the shelf.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptChoiceToAddBookToBasket(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to add a book to the basket.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n\r\n    Invariant:\r\n    - Book Name Length >= 1\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    # Invariant from design:\r\n    # Book Name Length\r\n    if len(book[\"name\"]) < 1:\r\n        raise ValueError(\"Invariant violated: Book name must have a minimum length of 1.\")\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef AcceptChoiceToAuditLibrary(response: str) -> str:\r\n    \"\"\"\r\n    Accepts the choice to audit the library.\r\n    \"\"\"\r\n    return response\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    PresentMenuAndAcceptUserChoice\r\n      -> AcceptChoiceToPlaceBooksOnShelf\r\n      -> AcceptChoiceToAuditLibrary\r\n      -> AcceptChoiceToAddBookToBasket\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            AcceptChoiceToPlaceBooksOnShelf(response)\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            AcceptChoiceToAuditLibrary(response)\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            AcceptChoiceToAddBookToBasket(response)\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","type":"file","uid":"4d3ba263-07a8-4a0f-aed8-0245575cf4b4","level":0,"collapsed":false,"isDirty":true,"mapping":[{"type":"ImportFrom","source_path":null,"uid":"4e6c3481-3301-4b66-b302-d048dd68b6b7","start_line":1,"end_line":1,"source":"from typing import Optional, Dict, Any"},{"type":"AnnAssign","source_path":null,"uid":"b73c6dd1-131e-47de-8ea5-6267074a2c22","start_line":5,"end_line":5,"source":"basket: list[dict] = []"},{"type":"AnnAssign","source_path":null,"uid":"c92b6518-20c1-485f-9122-6cf8cc988ca8","start_line":6,"end_line":6,"source":"book_shelf: dict[str, list[dict]] = {}"},{"type":"Expr","source_path":null,"uid":"06044242-df11-4e1f-a402-73a86cad6874","start_line":10,"end_line":12,"source":"\"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\""},{"type":"Expr","source_path":null,"uid":"011e64a2-a72d-4051-8d04-6d951515d6a6","start_line":13,"end_line":13,"source":"print(\"\\nMenu\")"},{"type":"Expr","source_path":null,"uid":"e015ad67-7da2-42d6-a884-cf1ea7679d5f","start_line":14,"end_line":14,"source":"print(\"----\")"},{"type":"Expr","source_path":null,"uid":"e4009f7d-7f33-4eda-8c83-952220ea2b55","start_line":15,"end_line":15,"source":"print(\"a: Add book to basket\")"},{"type":"Expr","source_path":null,"uid":"fb68ea59-5cdf-4eff-ac72-1b0f612c1096","start_line":16,"end_line":16,"source":"print(\"p: Place books on shelf\")"},{"type":"Expr","source_path":null,"uid":"ed7bcf22-f723-41fb-bb64-e8acd14fcfdf","start_line":17,"end_line":17,"source":"print(\"d: Audit library\")"},{"type":"Expr","source_path":null,"uid":"14fc45d7-dcd8-4630-a90c-0596fd7b0fa2","start_line":18,"end_line":18,"source":"print(\"Any other key: Exit\")"},{"type":"Assign","source_path":null,"uid":"e2326f3d-6fb1-4602-a937-1c04bcbc95c0","start_line":19,"end_line":19,"source":"response = input(\"Choice: \").strip().lower()"},{"type":"Return","source_path":null,"uid":"8cbf1ca8-f117-4dee-98aa-814635c6cbb4","start_line":20,"end_line":20,"source":"return response"},{"type":"Expr","source_path":null,"uid":"0b0e6a1f-a2ea-4b13-8d21-4ec6e27be925","start_line":24,"end_line":26,"source":"\"\"\"\r\n    Accepts the choice to place books on the shelf.\r\n    \"\"\""},{"type":"Return","source_path":null,"uid":"92b0161c-2743-41a6-a61b-9dd247d2199b","start_line":27,"end_line":27,"source":"return response"},{"type":"Expr","source_path":null,"uid":"b4d2068e-42f5-4e1a-98e9-fe10d