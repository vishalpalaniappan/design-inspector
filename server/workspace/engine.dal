"\"\"\"\r\n    Accepts the choice to add a book to the basket.\r\n    \"\"\""},{"type":"Return","source_path":null,"uid":"d15c2e88-fefb-4151-9740-540b2703f64d","start_line":75,"end_line":75,"source":"return response"},{"type":"Expr","source_path":null,"uid":"3ce373e9-b310-413c-b8f5-a0c46c5f11b7","start_line":79,"end_line":87,"source":"\"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n\r\n    Invariant:\r\n    - Book Name Length >= 1\r\n    \"\"\""},{"type":"Assign","source_path":null,"uid":"dd713535-123d-4bcd-923f-a54a43931d92","start_line":88,"end_line":88,"source":"name = input(\"Book name: \")"},{"type":"Assign","source_path":null,"uid":"d90e3586-8fc9-42a7-b655-753af4683df4","start_line":89,"end_line":89,"source":"genre = input(\"Book genre: \")"},{"type":"Assign","source_path":null,"uid":"89a2da3e-e9c4-485c-bf4a-41b27696e32e","start_line":91,"end_line":94,"source":"book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }"},{"type":"If","source_path":null,"uid":"2cc04892-e00b-4979-9eaf-a34bf8dbff45","start_line":98,"end_line":98,"source":["    if len(book[\"name\"]) < 1:"]},{"type":"Raise","source_path":null,"uid":"d096c990-67a2-46c0-bc2d-5da514123280","start_line":99,"end_line":99,"source":"raise ValueError(\"Invariant violated: Book name must have a minimum length of 1.\")"},{"type":"Return","source_path":null,"uid":"4043e3be-6736-480c-8b59-7afa91ec8e41","start_line":101,"end_line":101,"source":"return book"},{"type":"Expr","source_path":null,"uid":"cad29216-fbf2-4cd9-a072-38a5aa91694d","start_line":105,"end_line":110,"source":"\"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\""},{"type":"Expr","source_path":null,"uid":"b43bd93a-c6ac-4a6a-9c20-e33092d7be22","start_line":111,"end_line":111,"source":"basket.append(book)"},{"type":"Expr","source_path":null,"uid":"fa73f433-7a68-45a1-b746-d66d2e4a04f5","start_line":115,"end_line":117,"source":"\"\"\"\r\n    Accepts the choice to audit the library.\r\n    \"\"\""},{"type":"Return","source_path":null,"uid":"9cb5e821-d165-4ad4-b890-1f397c3f893f","start_line":118,"end_line":118,"source":"return response"},{"type":"Expr","source_path":null,"uid":"4b02d6c3-045b-40ed-b0b8-b728cdde5244","start_line":122,"end_line":126,"source":"\"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\""},{"type":"Return","source_path":null,"uid":"d2238b5f-f1dc-4ab9-826e-036cb6e0aeba","start_line":127,"end_line":130,"source":"return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }"},{"type":"Expr","source_path":null,"uid":"5aea9f0b-1c82-4e79-badf-cd5f1956ff45","start_line":134,"end_line":139,"source":"\"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\""},{"type":"Expr","source_path":null,"uid":"118dc7fd-c48f-4489-82db-24c2e5777e7c","start_line":140,"end_line":140,"source":"print(\"\\nAudit Report\")"},{"type":"Expr","source_path":null,"uid":"fb46913d-d927-445b-9515-6f92a36ec6a7","start_line":141,"end_line":141,"source":"print(\"------------\")"},{"type":"Expr","source_path":null,"uid":"889e2c8e-908f-4927-876e-cb0349c9b55b","start_line":142,"end_line":142,"source":"print(item)"},{"type":"Expr","source_path":null,"uid":"8612e14e-9222-4dad-8037-7db19d20970b","start_line":146,"end_line":154,"source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\""},{"type":"While","source_path":null,"uid":"d378cf7c-09f8-40fd-a2ec-cd1629b90915","start_line":155,"end_line":155,"source":["    while True:"]},{"type":"Assign","source_path":null,"uid":"b95fceec-b621-49b6-af19-fab8996f5867","start_line":156,"end_line":156,"source":"book = GetBookFromBasket()"},{"type":"If","source_path":null,"uid":"9624f5d2-b87e-4c59-9f2c-9ae924879f83","start_line":157,"end_line":157,"source":["        if book is None:"]},{"type":"Break","source_path":null,"uid":"a547c875-19b4-4eb8-b8bd-3c08982d0bdd","start_line":158,"end_line":158,"source":"break"},{"type":"Assign","source_path":null,"uid":"cf81f7d4-8ed7-466b-a023-18e8278194f3","start_line":160,"end_line":160,"source":"first_letter = GetFirstLetterOfBookName(book)"},{"type":"If","source_path":null,"uid":"a4b9b0a2-1cb9-4953-9860-e294e6126170","start_line":162,"end_line":162,"source":["        if first_letter not in book_shelf:"]},{"type":"Expr","source_path":null,"uid":"7dc98f64-a0b9-409e-8aeb-668ca75c3ce0","start_line":163,"end_line":163,"source":"CreateSlotOnBookShelf(first_letter)"},{"type":"Expr","source_path":null,"uid":"97fc9176-c810-4a3c-bee3-259e9bbfb7da","start_line":165,"end_line":165,"source":"AddBookToShelf(book, first_letter)"},{"type":"Expr","source_path":null,"uid":"4057ffd4-1263-4cc0-9947-b6d754b305a8","start_line":169,"end_line":175,"source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\""},{"type":"Assign","source_path":null,"uid":"415aa911-35eb-4643-9e20-451cbf1daff6","start_line":176,"end_line":176,"source":"book = AcceptBook()"},{"type":"Expr","source_path":null,"uid":"f8ad069d-ee89-49a5-8a2c-1d346d115b11","start_line":177,"end_line":177,"source":"PlaceBookInBasket(book)"},{"type":"Expr","source_path":null,"uid":"4f827984-d353-4096-8a6d-1c3f66e24e65","start_line":181,"end_line":187,"source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\""},{"type":"Assign","source_path":null,"uid":"069af450-5866-481f-a3bf-00fe70ccd9d0","start_line":188,"end_line":188,"source":"audit_report = GenerateAuditReport()"},{"type":"Expr","source_path":null,"uid":"583796f5-9b13-4e47-b47d-894e7ac72f7e","start_line":189,"end_line":189,"source":"HandBookToUser(audit_report)"},{"type":"Expr","source_path":null,"uid":"d164bc49-98ee-4643-89bb-479725bdc670","start_line":193,"end_line":203,"source":"\"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    PresentMenuAndAcceptUserChoice\r\n      -> AcceptChoiceToPlaceBooksOnShelf\r\n      -> AcceptChoiceToAuditLibrary\r\n      -> AcceptChoiceToAddBookToBasket\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\""},{"type":"While","source_path":null,"uid":"81d7183c-3767-4c38-837c-ef3cdc0ff1bf","start_line":204,"end_line":204,"source":["    while True:"]},{"type":"Assign","source_path":null,"uid":"2f7ab371-2da7-44bf-af5a-8ca41d9a1b77","start_line":205,"end_line":205,"source":"response = PresentMenuAndAcceptUserChoice()"},{"type":"If","source_path":null,"uid":"328c1d9a-d439-4074-abc5-a29c5db4c630","start_line":207,"end_line":207,"source":["        if response == \"p\":"]},{"type":"Expr","source_path":null,"uid":"587eac1c-adcf-4666-b136-253967831a15","start_line":208,"end_line":208,"source":"AcceptChoiceToPlaceBooksOnShelf(response)"},{"type":"Expr","source_path":null,"uid":"ed83e47a-df28-46ea-a6db-0b5427c521ea","start_line":209,"end_line":209,"source":"ExecutePlaceBooksOnShelfPath()"},{"type":"If","source_path":null,"uid":"5da44bfb-5815-415d-b6d2-aa941418c605","start_line":211,"end_line":211,"source":["        elif response == \"d\":"]},{"type":"Expr","source_path":null,"uid":"e3b4a8e4-b2c6-4f33-a0ed-e0e2656346df","start_line":212,"end_line":212,"source":"AcceptChoiceToAuditLibrary(response)"},{"type":"Expr","source_path":null,"uid":"eb966816-e702-4b4a-9b50-9b2a6025c676","start_line":213,"end_line":213,"source":"ExecuteAuditLibraryPath()"},{"type":"If","source_path":null,"uid":"65ba97e6-30b8-4446-a594-d4b76bb28ad5","start_line":215,"end_line":215,"source":["        elif response == \"a\":"]},{"type":"Expr","source_path":null,"uid":"f6db853d-1b7f-4dfc-bca1-481dd4deca40","start_line":216,"end_line":216,"source":"AcceptChoiceToAddBookToBasket(response)"},{"type":"Expr","source_path":null,"uid":"6a58e07c-e7ac-431f-b772-3e68992d6a6a","start_line":217,"end_line":217,"source":"ExecuteAddBookToBasketPath()"},{"type":"Break","source_path":null,"uid":"385297f4-8e2e-4117-a191-c6bb13fddc7c","start_line":220,"end_line":220,"source":"break"},{"type":"If","source_path":null,"uid":"d9aae340-47a7-426b-8a7a-4364b988ffb4","start_line":223,"end_line":223,"source":["if __name__ == \"__main__\":"]},{"type":"Expr","source_path":null,"uid":"b238e23a-b9e7-4867-a4b3-1e7a4ddbd1f4","start_line":224,"end_line":224,"source":"AcceptLoop()"}]}]}}