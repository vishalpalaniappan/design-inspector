{"graphs":{"_graphs":{"AcceptLoop":{"dal_engine_uid":"4e18f6a0-f59a-405f-9c80-14837df14b87","type":4,"nodes":[{"dal_engine_uid":"e852a920-8e44-429e-a46e-9f8ee58f3969","type":5,"_behavior":{"dal_engine_uid":"01e95246-bd6d-4a26-812c-e2b0a8ccb2c4","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PresentMenuAndAcceptUserChoice","_description":"Presents the menu to the user and accepts their choice."},"_goToBehaviorIds":["AcceptChoiceToPlaceBooksOnShelf","AcceptChoiceToAddBookToBasket","AcceptChoiceToAuditLibrary"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"5326cbdf-f06f-4690-820d-168e2ef90446","type":5,"_behavior":{"dal_engine_uid":"ece2a090-7947-43f4-a59e-88182a123fdf","_type":1,"_participants":[{"dal_engine_uid":"8e1c6437-187e-4a01-bdeb-bc257f98a031","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Response","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToPlaceBooksOnShelf","_description":""},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"a5e94a16-f6b3-4d25-a053-173b903d012d","type":5,"_behavior":{"dal_engine_uid":"c809dc9e-e549-439a-8f9c-daf9032a63b8","_type":1,"_participants":[{"dal_engine_uid":"b715c664-0ca6-4e3d-8c3b-86b870d40e37","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":"Name and genre of book."},{"dal_engine_uid":"ce1376dc-2886-4efa-ae17-f2fb563b5b4c","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Basket","_description":"Holds the books."}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GetBookFromBasket","_description":""},"_goToBehaviorIds":["GetFirstLetterOfBookName"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"e2726e2f-95b2-4f27-916c-3073d641f6de","type":5,"_behavior":{"dal_engine_uid":"97d6fc84-27c3-4d59-aea9-3a19de923ca7","_type":1,"_participants":[{"dal_engine_uid":"b048d871-4aec-404c-958c-63c80edb5043","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"BookShelf","_description":"Book shelf to place books in."}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"CreateSlotOnBookShelf","_description":""},"_goToBehaviorIds":["AddBookToShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"90ceebef-51fd-4d8e-ae50-bf1435763f86","type":5,"_behavior":{"dal_engine_uid":"e90d0a2e-56d1-41c3-8eeb-575ff4306dd3","_type":1,"_participants":[{"dal_engine_uid":"3f69307b-8ca2-4dbd-a0f7-1d927d2f810a","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""},{"dal_engine_uid":"865f970b-3f97-4147-9b8d-6437aea2b223","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"BookShelf","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToShelf","_description":""},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"5b1fe2b1-0c73-47e3-9cc2-43582cb8595d","type":5,"_behavior":{"dal_engine_uid":"b188ee5a-0266-442a-9366-63b5d3da8aa5","_type":1,"_participants":[{"dal_engine_uid":"1b30281f-0b91-4bf0-bae7-35efe0c7574b","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"FirstLetter","_description":"FirstLetterOfBooksName"}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GetFirstLetterOfBookName","_description":""},"_goToBehaviorIds":["AddBookToShelf","CreateSlotOnBookShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"93f857ee-8a19-440c-9348-014e34768859","type":5,"_behavior":{"dal_engine_uid":"00eaecb6-b8d9-4198-81ad-a225f106f54c","_type":1,"_participants":[{"dal_engine_uid":"5eb96c6c-d919-4393-b659-4f3c9c6f0d15","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Response","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAddBookToBasket","_description":""},"_goToBehaviorIds":["AcceptBook"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"ad5db342-4a7b-48fc-9408-ff8d05991f34","type":5,"_behavior":{"dal_engine_uid":"f4c73ebe-d887-4b18-a40d-601ff394dca2","_type":1,"_participants":[{"dal_engine_uid":"ffdab882-50e1-42d9-ae9e-5742ffe5329b","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Response","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAuditLibrary","_description":""},"_goToBehaviorIds":["GenerateAuditReport"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"b28fa95d-2793-44ef-906b-0aa1e92cb37b","type":5,"_behavior":{"dal_engine_uid":"422f5ab3-f62a-4f26-b859-6f0c7802705f","_type":1,"_participants":[{"dal_engine_uid":"1696bcf6-0d99-4bc1-8eee-6f8109731365","_type":3,"_invariants":[{"dal_engine_uid":"0d0b0881-b7b5-4ceb-84b3-d7b2c7bb501b","type":2,"invariantViolated":null,"invariantType":{"type":"min_length","label":"Minimum Length","properties":{"keys":{"label":"Key(s) of value in object","type":"Array","required":true,"value":["value","name"]},"minLength":{"label":"Minimum Length","type":"string","required":true,"value":"1"}},"invariantViolated":null},"traceId":null,"_name":"Book Name Length","_description":"Book name must have a minimum length of 1.","value":null}],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptBook","_description":"Accepts a book with a name and genre."},"_goToBehaviorIds":["PlaceBookInBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"461bb544-bf40-4ad0-902d-3bc19354dc0f","type":5,"_behavior":{"dal_engine_uid":"d43f941a-f4dc-4f85-9b3b-a8a59c880bfe","_type":1,"_participants":[{"dal_engine_uid":"57ec5c54-e0b5-486f-8041-45162b432ac3","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Basket","_description":""},{"dal_engine_uid":"26a17f69-c46b-4e70-9de1-e54022f577d1","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PlaceBookInBasket","_description":"Place book in basket."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"c9ff3bbe-330c-4a43-bda0-4f16ab5fdfcf","type":5,"_behavior":{"dal_engine_uid":"c2166025-5575-47ba-b940-321307a8a775","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GenerateAuditReport","_description":"Generate a report with all the books in the basket and all the books on the shelf."},"_goToBehaviorIds":["HandBookToUser"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"4cdd76aa-9a2b-4541-977d-c02fce29b2f5","type":5,"_behavior":{"dal_engine_uid":"22b47b48-051d-4bb4-b999-49327587ed9a","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"HandBookToUser","_description":"Give the report to the user."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false}],"name":"AcceptLoop","description":""}},"_activeGraph":{"dal_engine_uid":"4e18f6a0-f59a-405f-9c80-14837df14b87","type":4,"nodes":[{"dal_engine_uid":"e852a920-8e44-429e-a46e-9f8ee58f3969","type":5,"_behavior":{"dal_engine_uid":"01e95246-bd6d-4a26-812c-e2b0a8ccb2c4","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PresentMenuAndAcceptUserChoice","_description":"Presents the menu to the user and accepts their choice."},"_goToBehaviorIds":["AcceptChoiceToPlaceBooksOnShelf","AcceptChoiceToAddBookToBasket","AcceptChoiceToAuditLibrary"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"5326cbdf-f06f-4690-820d-168e2ef90446","type":5,"_behavior":{"dal_engine_uid":"ece2a090-7947-43f4-a59e-88182a123fdf","_type":1,"_participants":[{"dal_engine_uid":"8e1c6437-187e-4a01-bdeb-bc257f98a031","_type":3,"_invariants":[],"_ab