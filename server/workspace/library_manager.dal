"_start_line":69,"_end_line":69,"_source":["            if (len(basket) > 5):"]},{"dal_engine_uid":"84e518b1-4c81-4872-8dad-f2bdc9c03b06","_behaviorId":null,"_participants":[],"_uid":"9743b4a1-3afa-43ed-b930-f1aace58cccc","_start_line":70,"_end_line":70,"_source":"raise Exception(\"Basket is too heavy, I can't bring it to the shelf.\")"},{"dal_engine_uid":"9d9f262f-997a-4bad-bef8-2740f03fa5ce","_behaviorId":null,"_participants":[],"_uid":"f11d737c-759b-4d94-b3f5-8cc4b3ecb8c7","_start_line":71,"_end_line":71,"_source":"book_shelf = place_books_on_shelf_from_basket(book_shelf, basket)"},{"dal_engine_uid":"39ff69b1-e092-47ee-a8d0-bd439b0803d2","_behaviorId":null,"_participants":[],"_uid":"79b6ad8f-3177-4cee-a16d-0cf0d105723a","_start_line":73,"_end_line":73,"_source":["        elif response == \"d\":"]},{"dal_engine_uid":"3f1ecee2-5ddc-4ef4-9d66-07bb856529c5","_behaviorId":null,"_participants":[],"_uid":"e1988fc7-ed5e-49c3-abf3-4221f8e26947","_start_line":74,"_end_line":74,"_source":"audit = {\"uid\": str(uuid.uuid4()), \"value\":{\"Book Shelf\": book_shelf, \"Basket\": basket}}"},{"dal_engine_uid":"4de16b5f-3cbf-4f21-85a2-22b0bc34506b","_behaviorId":null,"_participants":[],"_uid":"3f2d7003-52a3-4e1b-9ac5-49edd7de07ee","_start_line":75,"_end_line":75,"_source":"print(\"\\nLibrary Audit:\", json.dumps(audit[\"value\"], indent=2))"},{"dal_engine_uid":"950e56f7-d038-46f9-b088-fe900905751e","_behaviorId":null,"_participants":[],"_uid":"47ceeb8e-4967-4e50-88dd-a9f6609e2519","_start_line":78,"_end_line":78,"_source":"break"},{"dal_engine_uid":"d95ab852-93aa-4978-9cb4-57bad32175f1","_behaviorId":null,"_participants":[],"_uid":"d343b245-fb6c-4ec2-9030-446b53d457a4","_start_line":80,"_end_line":80,"_source":["if __name__ == \"__main__\":"]},{"dal_engine_uid":"5b0ac976-3505-4e9b-b7d6-4bd98b494211","_behaviorId":null,"_participants":[],"_uid":"e515db98-3f69-4d55-8484-d3f9b9f55e6e","_start_line":81,"_end_line":81,"_source":"sys.exit(library_manager())"}],"_lastModified":"2026-04-11T17:05:42.489Z"}],"_key":"library_manager.py","_activeVersion":{"dal_engine_uid":"bdc99777-0653-489e-a800-f5f68cb74857","_versionId":"version1","_content":"import sys\r\nimport uuid\r\nimport json\r\n\r\ndef place_books_on_shelf_from_basket(book_shelf, basket):\r\n    '''\r\n    This function checks to see if there are books in the\r\n    basket and places it on the shelf. It continues until\r\n    there are no more books left.\r\n    \r\n    :param book_shelf: Object representing the bookshelf.\r\n    :param basket: Array representing the basket.\r\n    '''\r\n    while len(basket[\"value\"]) > 0:\r\n        book = basket[\"value\"].pop()\r\n        print(f\"Accepted book: {book['value']['name']} (Genre: {book['value']['genre']})\")\r\n        \r\n        firstLetter = book[\"value\"]['name'][0]\r\n\r\n        if (firstLetter not in book_shelf[\"value\"]):\r\n            book_shelf[\"value\"][firstLetter] = []\r\n\r\n        book_shelf[\"value\"][firstLetter].append(book)\r\n\r\n    return book_shelf\r\n\r\ndef accept_book():\r\n    '''\r\n    This function accepts the book from the user.\r\n    '''\r\n    print(\"\\nEnter book details:\")        \r\n    name = input(\"Book name: \")\r\n    genre = input(\"Genre: \")\r\n    book_details = {\"uid\": str(uuid.uuid4()), \"value\": {\"name\": name, \"genre\":genre}}\r\n    return book_details\r\n\r\ndef library_manager():\r\n    '''\r\n    This function serves the library manager. \r\n\r\n    It provides a menu that lets users add books to a basket and \r\n    place the books from the basket onto the shelf. It also allows\r\n    the user to display the contents of the library and finally, it\r\n    allows the user to exit the library.\r\n    '''\r\n\r\n    book_shelf = {\"uid\": str(uuid.uuid4()), \"value\":{}}\r\n\r\n    basket = {\"uid\": str(uuid.uuid4()), \"value\":[]}\r\n\r\n    while True:\r\n        \r\n        response = input(\r\n            \"\\n==========================\\n\"\\\r\n            \"         Menu:\\n\" \\\r\n            \"==========================\\n\"\\\r\n            \"Enter a: Add book.\\n\" \\\r\n            \"Enter p: Place books on shelf and continue.\\n\" \\\r\n            \"Enter d: Display contents of basket and book shelf.\\n\" \\\r\n            \"Enter any other key: Exit\\n\" \\\r\n            \"\\nResponse:\"\r\n        ).lower()\r\n\r\n        if response == \"a\":\r\n            book_details = accept_book()\r\n            basket[\"value\"].append(book_details)\r\n\r\n        elif response == \"p\":\r\n            if (len(basket) > 5):\r\n                raise Exception(\"Basket is too heavy, I can't bring it to the shelf.\")\r\n            book_shelf = place_books_on_shelf_from_basket(book_shelf, basket)\r\n\r\n        elif response == \"d\":\r\n            audit = {\"uid\": str(uuid.uuid4()), \"value\":{\"Book Shelf\": book_shelf, \"Basket\": basket}}\r\n            print(\"\\nLibrary Audit:\", json.dumps(audit[\"value\"], indent=2))\r\n\r\n        else:        \r\n            break\r\n\r\nif __name__ == \"__main__\":\r\n    sys.exit(library_manager())\r\n     ","_updatedContent":"import sys\r\nimport uuid\r\nimport json\r\n\r\ndef place_books_on_shelf_from_basket(book_shelf, basket):\r\n    '''\r\n    This function checks to see if there are books in the\r\n    basket and places it on the shelf. It continues until\r\n    there are no more books left.\r\n    \r\n    :param book_shelf: Object representing the bookshelf.\r\n    :param basket: Array representing the basket.\r\n    '''\r\n    while len(basket[\"value\"]) > 0:\r\n        book = basket[\"value\"].pop()\r\n        print(f\"Accepted book: {book['value']['name']} (Genre: {book['value']['genre']})\")\r\n        \r\n        firstLetter = book[\"value\"]['name'][0]\r\n\r\n        if (firstLetter not in book_shelf[\"value\"]):\r\n            book_shelf[\"value\"][firstLetter] = []\r\n\r\n        book_shelf[\"value\"][firstLetter].append(book)\r\n\r\n    return book_shelf\r\n\r\ndef accept_book():\r\n    '''\r\n    This function accepts the book from the user.\r\n    '''\r\n    print(\"\\nEnter book details:\")        \r\n    name = input(\"Book name: \")\r\n    genre = input(\"Genre: \")\r\n    book_details = {\"uid\": str(uuid.uuid4()), \"value\": {\"name\": name, \"genre\":genre}}\r\n    return book_details\r\n\r\ndef library_manager():\r\n    '''\r\n    This function serves the library manager. \r\n\r\n    It provides a menu that lets users add books to a basket and \r\n    place the books from the basket onto the shelf. It also allows\r\n    the user to display the contents of the library and finally, it\r\n    allows the user to exit the library.\r\n    '''\r\n\r\n    book_shelf = {\"uid\": str(uuid.uuid4()), \"value\":{}}\r\n\r\n    basket = {\"uid\": str(uuid.uuid4()), \"value\":[]}\r\n\r\n    while True:\r\n        \r\n        response = input(\r\n            \"\\n==========================\\n\"\\\r\n            \"         Menu:\\n\" \\\r\n            \"==========================\\n\"\\\r\n            \"Enter a: Add book.\\n\" \\\r\n            \"Enter p: Place books on shelf and continue.\\n\" \\\r\n            \"Enter d: Display contents of basket and book shelf.\\n\" \\\r\n            \"Enter any other key: Exit\\n\" \\\r\n            \"\\nResponse:\"\r\n        ).lower()\r\n\r\n        if response == \"a\":\r\n            book_details = accept_book()\r\n            basket[\"value\"].append(book_details)\r\n\r\n        elif response == \"p\":\r\n            if (len(basket) > 5):\r\n                raise Exception(\"Basket is too heavy, I can't bring it to the shelf.\")\r\n            book_shelf = place_books_on_shelf_from_basket(book_shelf, basket)\r\n\r\n        elif response == \"d\":\r\n            audit = {\"uid\": str(uuid.uuid4()), \"value\":{\"Book Shelf\": book_shelf, \"Basket\": basket}}\r\n            print(\"\\nLibrary Audit:\", json.dumps(audit[\"value\"], indent=2))\r\n\r\n        else:        \r\n            break\r\n\r\nif __name__ == \"__main__\":\r\n    sys.exit(library_manager())\r\n     ","_isDirty":true,"_statementIndex":[{"dal_engine_uid":"b8f8d57e-b2ed-41ac-a530-b5e98638c0cd","_behaviorId":null,"_participants":[],"_uid":"461002e7-9c4c-4bfc-beee-96bfe9950164","_start_line":1,"_end_line":1,"_source":"import sys"},{"dal_engine_uid":"ea109337-c15f-4c65-8511-6ce65e3f5966","_behaviorId":null,"_participants":[],"_uid":"79d1c2ef-1b60-482f-8379-475c3835b9ff","_start_line":2,"_end_line":2,"_source":"import uuid"},{"dal_engine_uid":"9f4df79e-1582-4c09-a5ee-2e3add894a35","_behaviorId":null,"_participants":[],"_uid":"d4ff26a4-29b8-4061-b43c-37644c4c2a7d","_start_line":3,"_end_line":3,"_source":"import json"},{"dal_engine_uid":"6e56ad04-ae26-4e43-a35a-e370a13821d1","_behaviorId":null,"_participants":[],"_uid":"eb772209-35ba-4e10-85ca-b8eede1fcea2","_start_line":6,"_end_line":13,"_source":"'''\r\n    This function checks to see if there are books in the\r\n    basket and places it on the shelf. It continues until\r\n    there are no more books left.\r\n    \r\n    :param book_shelf: Object representing the bookshelf.\r\n    :param basket: Array representing the basket.\r\n    '''"},{"dal_engine_uid":"7bbc3589-4370-4a60-8fc8-f2dba06de6b1","_behaviorId":null,"_participants":[],"_uid":"07805690-7552-4111-89b9-d8a5444230e3","_start_line":14,"_end_line":14,"_source":["    while len(basket[\"value\"]) > 0:"]},{"dal_engine_uid":"ba5f9605-6a98-410a-85c1-a121ab0e9633","_behaviorId":null,"_participants":[],"_uid":"3988fb15-35d8-4671-b3aa-764d0043b2a2","_start_line":15,"_end_line":15,"_source":"book = basket[\"value\"].pop()"},{"dal_engine_uid":"d7d8ff60-9f62-448b-a1d2-cbceeb458511","_behaviorId":null,"_participants":[],"_uid":"6d16e8b8-3935-49df-b1b7-f59cad771691","_start_line":16,"_end_line":16,"_source":"print(f\"Accepted book: {book['value']['name']} (Genre: {book['value']['genre']})\")"},{"dal_engine_uid":"e0136df2-ac8a-4da4-9da7-0ffa9f18d775","_behaviorId":null,"_participants":[],"_uid":"142386