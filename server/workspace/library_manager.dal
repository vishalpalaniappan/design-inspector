id":"f6daf36d-ea53-43ab-8f91-f3b2d2b3b0e8","_behaviorId":null,"_participants":[],"_uid":"910ac6d4-d7d3-4ded-99c2-2c832c28c606","_start_line":81,"_end_line":86,"_source":"\"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\""},{"dal_engine_uid":"1c1110e5-4449-4f59-895e-a563eaa89bd1","_behaviorId":"PlaceBookInBasket","_participants":[],"_uid":"a6838519-ecf3-4661-bcf0-85b40c67dcce","_start_line":87,"_end_line":87,"_source":"basket.append(book)"},{"dal_engine_uid":"81de4232-d8ba-4483-b157-9d53e3316dfa","_behaviorId":null,"_participants":[],"_uid":"077c8549-7431-471e-8093-45462f151047","_start_line":91,"_end_line":95,"_source":"\"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\""},{"dal_engine_uid":"5b6ad7a8-b7db-4bad-bd2d-e6bcc3e83aa6","_behaviorId":"GenerateAuditReport","_participants":[],"_uid":"0fc34c09-b059-43d5-8ffa-ee4f39916dc7","_start_line":96,"_end_line":99,"_source":"return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }"},{"dal_engine_uid":"40718ec0-a5f3-4884-b200-82bc94999c64","_behaviorId":null,"_participants":[],"_uid":"e3841504-c455-4693-9f53-053a4e889680","_start_line":103,"_end_line":108,"_source":"\"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\""},{"dal_engine_uid":"5037ed12-2d95-40c3-8a3b-08d584bfaa99","_behaviorId":"HandBookToUser","_participants":[],"_uid":"c099f61d-196d-44f4-a996-856c312d91f1","_start_line":109,"_end_line":109,"_source":"print(\"\\nAudit Report\")"},{"dal_engine_uid":"484adb39-3168-463f-a59d-122afe5579fd","_behaviorId":"HandBookToUser","_participants":[],"_uid":"c59f34a3-891b-4b04-bb16-38055884ec74","_start_line":110,"_end_line":110,"_source":"print(\"------------\")"},{"dal_engine_uid":"e7429e08-6612-4cf3-99dc-dd389ee2b837","_behaviorId":"HandBookToUser","_participants":[],"_uid":"cd8497e8-43d9-4727-8303-0e302310d803","_start_line":111,"_end_line":111,"_source":"print(item)"},{"dal_engine_uid":"bb0a221c-912d-4d3d-9270-d156b0d7eff0","_behaviorId":null,"_participants":[],"_uid":"47808791-f019-401f-abc6-2fda68687ae0","_start_line":115,"_end_line":123,"_source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\""},{"dal_engine_uid":"02635311-d483-4d2f-aab5-0d62d4167041","_behaviorId":null,"_participants":[],"_uid":"4e1c2ad7-9eb1-4681-bb58-23b60bc532d3","_start_line":124,"_end_line":124,"_source":["    while True:"]},{"dal_engine_uid":"1215d589-45cc-44fb-bc01-a98bab385c16","_behaviorId":null,"_participants":[],"_uid":"1b49048b-684c-4728-ac2c-3e6212ee7370","_start_line":125,"_end_line":125,"_source":"book = GetBookFromBasket()"},{"dal_engine_uid":"c76a8257-8a96-44d6-811e-c848188374db","_behaviorId":null,"_participants":[],"_uid":"bbf7611d-a2e1-4d07-a90f-426adc373a5e","_start_line":126,"_end_line":126,"_source":["        if book is None:"]},{"dal_engine_uid":"1bea9768-edf6-4f8f-af71-543c3a9f022d","_behaviorId":null,"_participants":[],"_uid":"4b492a9e-2e3f-4243-a22b-6321f17825b4","_start_line":127,"_end_line":127,"_source":"break"},{"dal_engine_uid":"63eb0b43-d014-483d-b4bf-653d56f19ab7","_behaviorId":null,"_participants":[],"_uid":"bdff1d1b-c56e-437b-84a9-2dc9ff2a1fce","_start_line":129,"_end_line":129,"_source":"first_letter = GetFirstLetterOfBookName(book)"},{"dal_engine_uid":"71accf17-3721-45a9-a8f3-802f9a346915","_behaviorId":null,"_participants":[],"_uid":"6d62e52d-dcd7-47c3-acc9-aed65694bd56","_start_line":131,"_end_line":131,"_source":["        if first_letter not in book_shelf:"]},{"dal_engine_uid":"4c18610d-9cee-4688-a6af-606f7b589c23","_behaviorId":null,"_participants":[],"_uid":"01be3516-d9c6-4917-a986-ce3207af9ff1","_start_line":132,"_end_line":132,"_source":"CreateSlotOnBookShelf(first_letter)"},{"dal_engine_uid":"d081e34c-bd10-4db3-91c6-fa6c8c3dcdbd","_behaviorId":null,"_participants":[],"_uid":"287c8c19-8618-48b9-9bca-c8f62342cb99","_start_line":134,"_end_line":134,"_source":"AddBookToShelf(book, first_letter)"},{"dal_engine_uid":"da0076a1-87b5-4cd7-b793-184dd0f5a05f","_behaviorId":null,"_participants":[],"_uid":"e3b8c86f-05cd-48fe-ae77-99a92f266a78","_start_line":138,"_end_line":144,"_source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\""},{"dal_engine_uid":"a4bb2be7-b4f7-4850-8f2c-f98b0e57c317","_behaviorId":null,"_participants":[],"_uid":"1f740de0-b2c1-4212-9ee3-92cb583d9093","_start_line":145,"_end_line":145,"_source":"book = AcceptBook()"},{"dal_engine_uid":"78757df7-c954-40a8-b491-1c8802d2e644","_behaviorId":null,"_participants":[],"_uid":"a82b8b1e-ec9c-452c-a1cb-cdc856772ad7","_start_line":146,"_end_line":146,"_source":"PlaceBookInBasket(book)"},{"dal_engine_uid":"2b197d2e-8bc7-4a57-8a22-30b11caadbc8","_behaviorId":null,"_participants":[],"_uid":"6c049e61-aadb-4323-8594-d89631623666","_start_line":150,"_end_line":156,"_source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\""},{"dal_engine_uid":"d2be55b4-05d8-4d73-8e05-25ab4833a4eb","_behaviorId":null,"_participants":[],"_uid":"5a71868b-5017-4162-a841-5834e5800a0f","_start_line":157,"_end_line":157,"_source":"audit_report = GenerateAuditReport()"},{"dal_engine_uid":"9a6c435f-e06f-4456-96ac-46328e54df20","_behaviorId":null,"_participants":[],"_uid":"8f11de26-5254-4faa-a7eb-6b668c5feff6","_start_line":158,"_end_line":158,"_source":"HandBookToUser(audit_report)"},{"dal_engine_uid":"62358094-8148-446b-8e54-a50f306db303","_behaviorId":null,"_participants":[],"_uid":"e56c0e22-88ec-4f93-a752-bcfa307608c8","_start_line":162,"_end_line":167,"_source":"\"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\""},{"dal_engine_uid":"f8ac4f79-9ef8-41b6-8cac-baf7c2fb9384","_behaviorId":"HandBookToUser","_participants":[],"_uid":"ee7fe724-be43-4eb7-9cf9-a22b01607f3c","_start_line":168,"_end_line":168,"_source":["    while True:"]},{"dal_engine_uid":"53a2f458-b9d7-4f05-b41c-a18776eb682b","_behaviorId":"HandBookToUser","_participants":[],"_uid":"59c89d43-2ba7-4570-9e32-f482592e5c8e","_start_line":169,"_end_line":169,"_source":"response = PresentMenuAndAcceptUserChoice()"},{"dal_engine_uid":"b88a0a75-3bc6-4741-84c2-365bb40261d9","_behaviorId":"HandBookToUser","_participants":[],"_uid":"efcccc16-8704-487f-adad-f21a5cbe37e9","_start_line":171,"_end_line":171,"_source":["        if response == \"p\":"]},{"dal_engine_uid":"5dcd9378-a59c-430f-be29-bec3c9000a99","_behaviorId":"HandBookToUser","_participants":[],"_uid":"d3e6573c-22e1-48b5-bbdf-afd9df4bcaf0","_start_line":172,"_end_line":172,"_source":"ExecutePlaceBooksOnShelfPath()"},{"dal_engine_uid":"c5b2e41d-98a4-4ce4-b4f1-d4e2a838af31","_behaviorId":"HandBookToUser","_participants":[],"_uid":"d7bec412-9ff7-48e1-88a0-362ecd11af8d","_start_line":174,"_end_line":174,"_source":["        elif response == \"d\":"]},{"dal_engine_uid":"c11259e7-3f92-4046-b53d-ca823deccbdd","_behaviorId":"HandBookToUser","_participants":[],"_uid":"f06eb5dd-a327-48d3-ae6a-fa24f7b35d83","_start_line":175,"_end_line":175,"_source":"ExecuteAuditLibraryPath()"},{"dal_engine_uid":"9a3aaca9-90a9-4c53-844c-c145f3425d6a","_behaviorId":"HandBookToUser","_participants":[],"_uid":"6ba3b654-e633-4348-9171-630fdf8ba82a","_start_line":177,"_end_line":177,"_source":["        elif response == \"a\":"]},{"dal_engine_uid":"c855c3df-df21-430b-8333-1bc8ad4aec31","_behaviorId":"HandBookToUser","_participants":[],"_uid":"9fad64d3-7f8d-4f1c-9a70-ce690a1dfa7f","_start_line":178,"_end_line":178,"_source":"ExecuteAddBookToBasketPath()"},{"dal_engine_uid":"c8fa66c7-8c74-4cae-9766-51a221fc5914","_behaviorId":null,"_participants":[],"_uid":"ec59e9fa-1f53-4249-bdcd-9b2d61867b17","_start_line":181,"_end_line":181,"_source":"break"},{"dal_engine_uid":"f8afe8c8-01ef-48cc-85b5-afb793f6a7c9","_behaviorId":null,"_participants":[],"_uid":"03b0d72e-7a70-4144-9bd0-8920d29b8599","_start_line":184,"_end_line":184,"_source":["if __name__ == \"__main__\":"]},{"dal_engine_uid":"35052540-89ed-4279-97ae-460c5d9403e7","_behaviorId":null,"_participants":[],"_uid":"ef36aa48-9579-411f-882b-f32e06f95261","_start_line":185,"_end_line":185,"_source":"AcceptLoop()"}],"_lastModified":"2026-04-11T23:14:23.679Z"}],"_key":"library_manager.py","_activeVersion":{"dal_engine_uid":"ebb38e30-f265-4902-95a8-fce9ff6d2436","_versionId":"version1","_content":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_updatedContent":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_isDirty":true,"_statementIndex":[{"dal_engine_uid":"72580db7-6d1c-4271-8576-6617cf9c2e3d","_behaviorId":null,"_participants":[],"_uid":"ee1b2a50-828f-4cd6-9be2-1cfecbdf5596","_start_line":1,"_end_line":1,"_source":"from typing import Optional"},{"dal_engine_uid":"3a632807-4e58-406e-a89e-3d773d600ade","_behaviorId":null,"_participants":[],"_uid":"bd30c30d-479f-418b-ad92-dd4ccb92f733","_start_line":3,"_end_line":3,"_source":"basket: list[dict] = []"},{"dal_engine_uid":"1ffd0590-2e1b-4db6-b9cb-72169a3c9bc7","_behaviorId":null,"_participants":[],"_uid":"63938569-09d1-4f53-a65e-4b70b939ff9e","_start_line":4,"_end_line":4,"_source":"book_shelf: dict[str, list[dict]] = {}"},{"dal_engine_uid":"5cccfff2-1f34-48c0-bd92-c7bb6b13160c","_behaviorId":null,"_participants":[],"_uid":"8aaaee03-a89a-4814-b17d-57413ddcd120","_start_line":8,"_end_line":10,"_source":"\"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\""},{"dal_engine_uid":"791137ab-7db4-48cd-84a3-81c1104607d0","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"7e5c28f8-eb5c-4248-b52b-5afdd300153e","_start_line":11,"_end_line":11,"_source":"print(\"\\nMenu\")"},{"dal_engine_uid":"1720fb1a-3a96-4b7c-ad72-d1d5bdd54cac","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"9e284481-7881-46b6-bfd7-cac15f2fda3e","_start_line":12,"_end_line":12,"_source":"print(\"----\")"},{"dal_engine_uid":"4a10e451-006a-470f-8ad4-71fa0325ae6e","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"d1f2cba2-0241-4d22-abb2-cc2a30d67f73","_start_line":13,"_end_line":13,"_source":"print(\"a: Add book to basket\")"},{"dal_engine_uid":"681ee732-0275-471e-87cf-0921ada4143c","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"67084860-2b13-4965-9cd7-4a621cd14aec","_start_line":14,"_end_line":14,"_source":"print(\"p: Place books on shelf\")"},{"dal_engine_uid":"37945bfc-e19f-4d9f-84f4-712d8193d1ee","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"e17ebfe3-ecbf-4523-910a-d7af5dcfdd80","_start_line":15,"_end_line":15,"_source":"print(\"d: Audit library\")"},{"dal_engine_uid":"b01030c5-0008-4df0-b0e7-d6aae09192