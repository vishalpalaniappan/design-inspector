tion":""},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"d6f6e344-de7f-4962-a131-f44d73e61d45","type":5,"_behavior":{"dal_engine_uid":"dff38a84-23ee-461c-84f8-ae58c2bedd0c","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PlaceBookInBasket","_description":""},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"3833deb0-dd27-434b-bd53-1126ac7a97b3","type":5,"_behavior":{"dal_engine_uid":"9e2d8231-1f1e-4db9-b7ee-952291f92e8a","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PresentMenuAndAcceptUserChoice","_description":""},"_goToBehaviorIds":["GetBookFromBasket","GenerateAuditReport","AcceptBook"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"44b136f2-04cf-44a7-bb6f-f45b838db2ea","type":5,"_behavior":{"dal_engine_uid":"df1d2bfb-21b3-4652-95a9-9d35b484a244","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GetFirstLetterOfBookName","_description":""},"_goToBehaviorIds":["CreateSlotOnBookShelf","AddBookToShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"d4570175-3a06-493b-8ca1-3866d3e244b4","type":5,"_behavior":{"dal_engine_uid":"57a2ff63-85dd-4725-ae30-e5a74347fc0a","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"CreateSlotOnBookShelf","_description":""},"_goToBehaviorIds":["AddBookToShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"87c97bf1-8e61-4ca8-8c03-3e8617935b6b","type":5,"_behavior":{"dal_engine_uid":"cd70204b-74bb-42ea-846e-fbd2471a9204","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToShelf","_description":""},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false}],"name":"default graph","description":""}},"implementation":{"dal_engine_uid":"bc274d32-8070-4127-bf9e-f684da5e8b83","_files":[{"dal_engine_uid":"baaa3960-9d12-4091-971b-225d095f82dd","_name":"library_manager.py","_versions":[{"dal_engine_uid":"ebb38e30-f265-4902-95a8-fce9ff6d2436","_versionId":"version1","_content":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_updatedContent":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_isDirty":true,"_statementIndex":[{"dal_engine_uid":"72580db7-6d1c-4271-8576-6617cf9c2e3d","_behaviorId":null,"_participants":[],"_uid":"ee1b2a50-828f-4cd6-9be2-1cfecbdf5596","_start_line":1,"_end_line":1,"_source":"from typing import Optional"},{"dal_engine_uid":"3a632807-4e58-406e-a89e-3d773d600ade","_behaviorId":null,"_participants":[],"_uid":"bd30c30d-479f-418b-ad92-dd4ccb92f733","_start_line":3,"_end_line":3,"_source":"basket: list[dict] = []"},{"dal_engine_uid":"1ffd0590-2e1b-4db6-b9cb-72169a3c9bc7","_behaviorId":null,"_participants":[],"_uid":"63938569-09d1-4f53-a65e-4b70b939ff9e","_start_line":4,"_end_line":4,"_source":"book_shelf: dict[str, list[dict]] = {}"},{"dal_engine_uid":"5cccfff2-1f34-48c0-bd92-c7bb6b13160c","_behaviorId":null,"_participants":[],"_uid":"8aaaee03-a89a-4814-b17d-57413ddcd120","_start_line":8,"_end_line":10,"_source":"\"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\""},{"dal_engine_uid":"791137ab-7db4-48cd-84a3-81c1104607d0","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"7e5c28f8-eb5c-4248-b52b-5afdd300153e","_start_line":11,"_end_line":11,"_source":"print(\"\\nMenu\")"},{"dal_engine_uid":"1720fb1a-3a96-4b7c-ad72-d1d5bdd54cac","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"9e284481-7881-46b6-bfd7-cac15f2fda3e","_start_line":12,"_end_line":12,"_source":"print(\"----\")"},{"dal_engine_uid":"4a10e451-006a-470f-8ad4-71fa0325ae6e","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"d1f2cba2-0241-4d22-abb2-cc2a30d67f73","_start_line":13,"_end_line":13,"_source":"print(\"a: Add book to basket\")"},{"dal_engine_uid":"681ee732-0275-471e-87cf-0921ada4143c","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"67084860-2b13-4965-9cd7-4a621cd14aec","_start_line":14,"_end_line":14,"_source":"print(\"p: Place books on shelf\")"},{"dal_engine_uid":"37945bfc-e19f-4d9f-84f4-712d8193d1ee","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"e17ebfe3-ecbf-4523-910a-d7af5dcfdd80","_start_line":15,"_end_line":15,"_source":"print(\"d: Audit library\")"},{"dal_engine_uid":"b01030c5-0008-4df0-b0e7-d6aae09192c7","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"cc7118b4-ad15-452a-a000-6ceed1987ad0","_start_line":16,"_end_line":16,"_source":"print(\"Any other key: Exit\")"},{"dal_engine_uid":"9592fc2c-f1b0-43f6-a80a-7ffdcc12ba0d","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"8ea015ee-bcce-4acf-8ffa-f62fb155f5eb","_start_line":17,"_end_line":17,"_source":"response = input(\"Choice: \").strip().lower()"},{"dal_engine_uid":"8c385791-53c8-48ab-bc59-06190745fe1f","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"fcfba5b1-6dbe-44f8-ad13-9b25169659fe","_start_line":18,"_end_line":18,"_source":"return response"},{"dal_engine_uid":"930490a3-0dbc-4005-a15c-92afd9927307","_behaviorId":null,"_participants":[],"_uid":"a2741274-f59d-4362-b72c-e77a83117573","_start_line":22,"_end_line":27,"_source":"\"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\""},{"dal_engine_uid":"580508cb-23bc-4b70-b77d-a972473050ba","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"5f918d00-e1b4-4e36-a09d-928e54affaf0","_start_line":28,"_end_line":28,"_source":["    if not basket:"]},{"dal_engine_uid":"081ac4f8-2d81-48d4-b6ea-c6e9150d3951","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"0066ace3-245d-4fb0-87a5-59d38083ca16","_start_line":29,"_end_line":29,"_source":"return None"},{"dal_engine_uid":"e6317adc-149f-4729-966e-4f8d88085d3f","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"0eac3b39-8fdd-4019-88ca-2920b3200c46","_start_line":30,"_end_line":30,"_source":"return basket.pop(0)"},{"dal_engine_uid":"16a224ff-1a16-4a63-92cc-40cb65f33e7d","_behaviorId":null,"_participants":[],"_uid":"ff59413c-4ff2-4f0e-9db4-632e0844c3ed","_start_line":34,"_end_line":38,"_source":"\"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\""},{"dal_engine_uid":"7de1be2a-6f3b-4b08-8773-47d1a940ffc6","_behaviorId":"GetFirstLetterOfBookName","_participants":[],"_uid":"129f8a89-fc65-4933-9854-7b4f1c61df71","_start_line":39,"_end_line":39,"_source":"return book[\"name\"][0]"},{"dal_engine_uid":"3b18804f-badc-4dbe-a435-2254a716c1f9","_behaviorId":null,"_participants":[],"_uid":"adb3e66b-119a-4ddf-b56d-e9248ed9b258","_start_line":43,"_end_line":47,"_source":"\"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\""},{"dal_engine_uid":"400ffc9f-bc4c-4f1d-ad5e-220481873f5e","_behaviorId":"CreateSlotOnBookShelf","_participants":[],"_uid":"d304928b-ddf8-4af8-b58c-14cb9f232305","_start_line":48,"_end_line":48,"_source":["    if first_letter not in book_shelf:"]},{"dal_engine_uid":"7282e32e-d8c6-4da5-86c7-b5