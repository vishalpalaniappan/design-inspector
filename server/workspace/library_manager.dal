[],"_uid":"67a98480-783b-42cb-ba16-4e1ddb0c7aff","_start_line":132,"_end_line":132,"_source":"CreateSlotOnBookShelf(first_letter)"},{"dal_engine_uid":"429fae51-c795-41aa-a370-71191c41df30","_behaviorId":null,"_participants":[],"_uid":"da922bc1-ebfa-445b-a2d9-3b17d3f762c9","_start_line":134,"_end_line":134,"_source":"AddBookToShelf(book, first_letter)"},{"dal_engine_uid":"6dd3ab2d-84ff-4b19-9b61-78410a9556fd","_behaviorId":null,"_participants":[],"_uid":"47e3cfad-e7d7-4ce7-948b-7c7d1a2ece5b","_start_line":138,"_end_line":144,"_source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\""},{"dal_engine_uid":"757a8c2c-5460-4008-a09f-8ba60d0981d9","_behaviorId":null,"_participants":[],"_uid":"f0c6eefd-7199-4f46-817e-7830449e6210","_start_line":145,"_end_line":145,"_source":"book = AcceptBook()"},{"dal_engine_uid":"71ba0f87-21f9-402e-bea0-f1aa97c76982","_behaviorId":null,"_participants":[],"_uid":"4c35e7c8-0dfe-4e44-9547-79efe348a82b","_start_line":146,"_end_line":146,"_source":"PlaceBookInBasket(book)"},{"dal_engine_uid":"22f2db3f-b949-4483-a49d-2e4cfcfaca93","_behaviorId":null,"_participants":[],"_uid":"8565b182-e8c0-4902-8bc6-6e5f566c2cf1","_start_line":150,"_end_line":156,"_source":"\"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\""},{"dal_engine_uid":"c0e5feba-8716-4b7a-8d96-a68ec8984435","_behaviorId":null,"_participants":[],"_uid":"cd879ba0-af81-4d94-8e7e-73ae92504278","_start_line":157,"_end_line":157,"_source":"audit_report = GenerateAuditReport()"},{"dal_engine_uid":"039fac5d-6cd9-4ea1-9cd3-dc80920111f5","_behaviorId":null,"_participants":[],"_uid":"8d311621-8db3-4b43-8188-0edd5555eb44","_start_line":158,"_end_line":158,"_source":"HandBookToUser(audit_report)"},{"dal_engine_uid":"6c43cc84-66a1-424c-9287-2392ffe20aee","_behaviorId":null,"_participants":[],"_uid":"201e5001-9080-45e9-a186-a47142f9fcd7","_start_line":162,"_end_line":167,"_source":"\"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\""},{"dal_engine_uid":"101032d9-b85e-49a8-8c3a-960d615d2eaa","_behaviorId":null,"_participants":[],"_uid":"00934a7d-9480-45a0-aa81-3be825d09477","_start_line":168,"_end_line":168,"_source":["    while True:"]},{"dal_engine_uid":"d980fcc8-feef-457e-a713-a823c6819aba","_behaviorId":null,"_participants":[],"_uid":"eac5a257-4ae3-43cf-a5fe-d5df03d4596b","_start_line":169,"_end_line":169,"_source":"response = PresentMenuAndAcceptUserChoice()"},{"dal_engine_uid":"40350ea1-7942-45c2-9513-dc9a0c6f3d16","_behaviorId":null,"_participants":[],"_uid":"f75dd996-d84d-4f5d-876a-f2ddf722f62d","_start_line":171,"_end_line":171,"_source":["        if response == \"p\":"]},{"dal_engine_uid":"5aad65f2-9f86-47f1-a23a-3c5b0b510e93","_behaviorId":null,"_participants":[],"_uid":"699728f0-fa26-4fd0-8de1-b3e921d4234e","_start_line":172,"_end_line":172,"_source":"ExecutePlaceBooksOnShelfPath()"},{"dal_engine_uid":"433975ee-5cd1-419d-a5d9-8a81fd607a6a","_behaviorId":null,"_participants":[],"_uid":"eaa7dc5a-aadf-4eb6-b6f1-f6697cbe250e","_start_line":174,"_end_line":174,"_source":["        elif response == \"d\":"]},{"dal_engine_uid":"489fab7b-5aa7-497c-ba8f-7a32759042a3","_behaviorId":null,"_participants":[],"_uid":"1de52231-1d84-48e4-a6d3-75bd447cc5a1","_start_line":175,"_end_line":175,"_source":"ExecuteAuditLibraryPath()"},{"dal_engine_uid":"b265a397-359f-40e7-8ca2-538e8e7c947c","_behaviorId":null,"_participants":[],"_uid":"6d135971-9025-4be8-ba64-e2a68d30f47b","_start_line":177,"_end_line":177,"_source":["        elif response == \"a\":"]},{"dal_engine_uid":"5ca9053f-76ec-4a72-a260-d50f0dd4f2db","_behaviorId":null,"_participants":[],"_uid":"fb3aa320-4787-40ea-9885-2a206ca316d1","_start_line":178,"_end_line":178,"_source":"ExecuteAddBookToBasketPath()"},{"dal_engine_uid":"6da2321d-acf5-462f-9e82-14b505ab3d1e","_behaviorId":null,"_participants":[],"_uid":"d0e89ae7-d6f4-4b10-a95b-8c50655b8e7f","_start_line":181,"_end_line":181,"_source":"break"},{"dal_engine_uid":"2c5f7ea8-b254-4424-b6b6-162b4ea16a4d","_behaviorId":null,"_participants":[],"_uid":"20227146-0513-4d39-be8a-af28c84f39dd","_start_line":184,"_end_line":184,"_source":["if __name__ == \"__main__\":"]},{"dal_engine_uid":"0f9bbe88-5aec-4b63-92ce-33999029e82e","_behaviorId":null,"_participants":[],"_uid":"7e37932c-995e-4134-8593-5b1d739b421c","_start_line":185,"_end_line":185,"_source":"AcceptLoop()"}],"_lastModified":"2026-04-11T17:15:24.844Z"}],"_key":"library_manager.py","_activeVersion":{"dal_engine_uid":"bdc99777-0653-489e-a800-f5f68cb74857","_versionId":"version1","_content":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_updatedContent":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_isDirty":true,"_statementIndex":[{"dal_engine_uid":"82eca017-9291-4d97-a77d-ec808ed07fbb","_behaviorId":null,"_participants":[],"_uid":"606f133e-124e-46e5-a229-2b97c873d926","_start_line":1,"_end_line":1,"_source":"from typing import Optional"},{"dal_engine_uid":"f53a095c