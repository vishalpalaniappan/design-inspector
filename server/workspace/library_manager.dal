ants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToShelf","_description":""},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"a88b5a27-8359-4691-a33a-7df9a7cfbf51","type":5,"_behavior":{"dal_engine_uid":"c16e00b5-661d-4077-ae57-632dad67cd67","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"PlaceBookInBasket","_description":""},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"948fe128-d715-4bbc-aecb-f9d585e822e5","type":5,"_behavior":{"dal_engine_uid":"8fd5a101-1778-4a81-ac74-d694cc741b75","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"HandBookToUser","_description":""},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"67eba1af-5179-42ff-8bb0-0edd7a808b5e","type":5,"_behavior":{"dal_engine_uid":"3d5ec7e4-9f40-4e17-ae14-94e2615756d0","_type":1,"_participants":[{"dal_engine_uid":"28632aa2-c6ae-4955-a3ed-792db37ea6c5","_type":3,"_invariants":[{"dal_engine_uid":"fd904e36-b88f-4c0d-af44-19a394ea188b","type":2,"invariantViolated":null,"invariantType":{"type":"min_length","label":"Minimum Length","properties":{"keys":{"label":"Key(s) of value in object","type":"Array","required":true,"value":["value","name"]},"minLength":{"label":"Minimum Length","type":"string","required":true,"value":"1"}},"invariantViolated":null},"traceId":null,"_name":"Book Name Length","_description":"Book name must be at least one character long.","value":null}],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptBook","_description":""},"_goToBehaviorIds":["PlaceBookInBasket"],"_isAtomic":false,"_isDesignFork":false}],"name":"default graph","description":""}},"implementation":{"_sourceFiles":[],"_entryPoint":"python3 library_manager.py"},"implementationV2":{"dal_engine_uid":"62e511b7-e4a1-411f-af5a-aa387c50d1d8","_files":[{"dal_engine_uid":"6e2e4256-7f11-41c0-87ca-95fb0284c0e7","_name":"library_manager.py","_versions":[{"dal_engine_uid":"bdc99777-0653-489e-a800-f5f68cb74857","_versionId":"version1","_content":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_updatedContent":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","_isDirty":true,"_statementIndex":[{"dal_engine_uid":"82eca017-9291-4d97-a77d-ec808ed07fbb","_behaviorId":null,"_participants":[],"_uid":"606f133e-124e-46e5-a229-2b97c873d926","_start_line":1,"_end_line":1,"_source":"from typing import Optional"},{"dal_engine_uid":"f53a095c-91f0-496a-82a7-601ca1779520","_behaviorId":null,"_participants":[],"_uid":"9012dbca-84c3-468e-a795-0a5cc8f2bb44","_start_line":3,"_end_line":3,"_source":"basket: list[dict] = []"},{"dal_engine_uid":"53e3803a-c229-4486-9f5b-2dd114770a4b","_behaviorId":null,"_participants":[],"_uid":"309a6787-9574-41fd-9812-b22f84778e2d","_start_line":4,"_end_line":4,"_source":"book_shelf: dict[str, list[dict]] = {}"},{"dal_engine_uid":"15f9a0eb-a3a5-41bd-a5b7-c1070a47b2fb","_behaviorId":null,"_participants":[],"_uid":"eafbf5ec-2a19-46cc-84f2-93c74df62118","_start_line":8,"_end_line":10,"_source":"\"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\""},{"dal_engine_uid":"c08935e6-a47d-4610-9b37-5fa3d30a8bbe","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"e168b395-c8d9-45a1-8f7b-d8f664c37f24","_start_line":11,"_end_line":11,"_source":"print(\"\\nMenu\")"},{"dal_engine_uid":"b6b7cb1f-70c3-4ef5-a0fb-2c44b7a679f1","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"5b081f1b-0b17-47af-90d8-5de33d78e7af","_start_line":12,"_end_line":12,"_source":"print(\"----\")"},{"dal_engine_uid":"c0b94259-ad07-4e21-a44d-4a77e34a8809","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"2ed6d34d-fe24-4be0-a16b-784b09aadcdc","_start_line":13,"_end_line":13,"_source":"print(\"a: Add book to basket\")"},{"dal_engine_uid":"7ef4cc22-2fb3-4534-9c4a-671fcbc40b51","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"0f9af853-5e61-447b-b1d2-875dc5bd26b7","_start_line":14,"_end_line":14,"_source":"print(\"p: Place books on shelf\")"},{"dal_engine_uid":"59631786-0860-4efa-b66a-ff1493f275a7","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"83e12e90-caa4-45c1-9b7a-cc647eea6190","_start_line":15,"_end_line":15,"_source":"print(\"d: Audit library\")"},{"dal_engine_uid":"5866f9ec-babc-4bd5-be62-ab2b8381983a","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"878636b4-5c02-4b94-8fcc-83d76ce5c694","_start_line":16,"_end_line":16,"_source":"print(\"Any other key: Exit\")"},{"dal_engine_uid":"89f00d52-27f7-4005-9875-f10534243fc9","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"6433f4ce-6df2-4334-8d52-283df46df2d5","_start_line":17,"_end_line":17,"_source":"response = input(\"Choice: \").strip().lower()"},{"dal_engine_uid":"2ac77c31-a5a8-4bc6-a198-d2d57909deaf","_behaviorId":"PresentMenuAndAcceptUserChoice","_participants":[],"_uid":"68c24bbc-d3d2-4816-958c-67584543bd27","_start_line":18,"_end_line":18,"_source":"return response"},{"dal_engine_uid":"a8d5aa0f-6db2-4e6a-b1e0-bf2d3931da8d","_behaviorId":null,"_participants":[],"_uid":"0e5673e8-7167-4968-86ae-fc282bac61e1","_start_line":22,"_end_line":27,"_source":"\"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\""},{"dal_engine_uid":"daeb88b6-1f09-47be-84fb-cdc71c54c8b5","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"86fe4a89-c6a9-4f17-859a-5e5ff1d6c5e5","_start_line":28,"_end_line":28,"_source":["    if not basket:"]},{"dal_engine_uid":"15db2ba1-e71c-4a9a-8a33-573c9121419a","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"41bc2042-ebc8-4c14-99f6-64603f06446b","_start_line":29,"_end_line":29,"_source":"return None"},{"dal_engine_uid":"856954f8-37f2-40e5-b058-993afb16cb4b","_behaviorId":"GetBookFromBasket","_participants":[],"_uid":"ae091f95-f321-4a76-a2fa-a4960ac968bc","_start_line":30,"_end_line":30,"_source":"return basket.pop(0)"},{"dal_engine_uid":"d748a6ef-1183-488f-9616-0902c66459c5","_behaviorId":null,"_participants":[],"_uid":"5583f235-b054-405b-b627-47968224a11c","_start_line":34,"_end_line":38,"_source":"\"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\""},{"dal_engine_uid":"14d57be2-6610-45bd-b057-3194c3ab5f0c","_behaviorId":"GetFirstLetterOfBookname","_participants":[],"_uid":"e5e0e0d1-fd24-46be-85ed-4270bf9c794c","_start_line":39,"_end_line":39,"_source":"return book[\"name\"][0]"},{"dal_engine_uid":"a9aaa0da-8974-45e7-8d8a-351fb9b8f60b","_behaviorId":null,"_participants":[],"_uid":"bc803316-9108-4720-86dd-21ef6af2e8c6","_start_line":43,"_end_line":47,"_source":"\"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\""},{"dal_engine_uid":"32fc3a31-bb5f-4e2f-9fab-483578fd3b3e","_behaviorId":"CreateSlotOnBookShelf","_participants":[],"_uid":"2c771d75-7e90-4340-9620-4aa5e3a2080f","_start_line":48,"_end_line":48,"_source":["    if first_letter not in book_shelf:"]},{"dal_engine_uid":"c37bfe77-d522-4955-a615-731b4f0ffca2","_behaviorId":"CreateSlotOnBookShelf","_participants":[],"_uid":"89216efa-685a-409e-9eda-48952d31c1bf","_start_line":49,"_end_line":49,"_source":"book_shelf[first_letter] = []"},{"dal_engine_uid":"2802c271-05c9-48ca-8544-959af0dff4da","_behaviorId":null,"_participants":[],"_uid":"6ca1e0b4-39a9-4460-a7e0-b3b5fe55c4f9","_start_line":53,"_end_line":58,"_source":"\"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\""},{"dal_engine_uid":"16d98ffb-b269-47bb-9e31-447a88e215ec","_behaviorId":"AddBookToShelf","_participants":[],"_uid":"496620d2-913a-4500-a4c9-3a20a1016333","_start_line":59,"_end_line":59,"_source":"book_shelf[first_letter].append(book)"},{"dal_engine_uid":"e634f556-d397-4efc-99af-bfa02e93b214","_behaviorId":null,"_participants":[],"_uid":"fb6d715d-9b0e-4142-b9e6-67cf1930f8ff","_start_line":63,"_end_line":68,"_source":"\"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\""},{"dal_engine_uid":"edcb9580-4f34-4b0d-b25e-9c57c0c9182a","_behaviorId":"AcceptBook","_participants":[],"_uid":"e511f2a2-8d67-4df6-9191-8172392df507","_start_line":69,"_end_line":69,"_source":"name = input(\"Book name: \")"},{"dal_engine_uid":"d52099cc-4b13-4fb6-a3bd-07c736ebec0c","_behaviorId":"AcceptBook","_participants":[],"_uid":"361712b9-7320-4df7-9221-b26e4edc8ca8","_start_line":70,"_end_line":70,"_source":"genre = input(\"Book genre: \")"},{"dal_engine_uid":"5faad325-94a8-4ab3-9417-bf05fcb2cbf2","_behaviorId":"AcceptBook","_participants":[],"_uid":"fa8afc79-f3e0-4ef7-8273-ab4eee57e418","_start_line":72,"_end_line":75,"_source":"book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }"},{"dal_engine_uid":"b8d4230a-d54a-4268-9225-429953cc3fb0","_behaviorId":"AcceptBook","_participants":[],"_uid":"95e25e33-713c-441a-b537-a11170db3de8","_start_line":77,"_end_line":77,"_source":"return book"},{"dal_engine_uid":"ee3c90fd-3e4a-401a-93c4-9c34427743ae","_behaviorId":null,"_participants":[],"_uid":"430b9838-e666-464d-a4f3-6c8a3a9e2117","_start_line":81,"_end_line":86,"_source":"\"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\""},{"dal_engine_uid":"ddcc489d-b5c1-42b5-8daa-80570151586b","_behaviorId":"PlaceBookInBasket","_participants":[],"_uid":"43e4507b-73ed-496b-ae05-f42d5a836b6b","_start_line":87,"_end_line":87,"_source":"basket.append(book)"},{"dal_engine_uid":"172287bf-c9d3-40ea-8bf6-4fe0c68c36e8","_behaviorId":null,"_participants":[],"_uid":"42ecb709-cebe-4c0b-9f59-7c1a37fc158f","_start_line":91,"_end_line":95,"_source":"\"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\""},{"dal_engine_uid":"4e0e5b76-3f11-4bfe-8d35-3fa829e25295","_behaviorId":"GenerateAuditReport","_participants":[],"_uid":"282f411d-7dc2-4aa6-b2b4-8cea58ca63b0","_start_line":96,"_end_line":99,"_source":"return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }"},{"dal_engine_uid":"b4f8a25d-4ce1-4dd5-a720-d779e3567943","_behaviorId":null,"_participants":[],"_uid":"b795f58d-4121-4852-8f26-64aff59982d9","_start_line":103,"_end_line":108,"_source":"\"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\""},{"dal_engine_uid":"87fc5bda-a1f4-4f28-9499-9ee02274b02f","_behaviorId":"HandBookToUser","_participants":[],"_uid":"2e85ac0b-bd55-4973-ac90-7ec061ec71fa","_start_line":109,"_end_line":109,"_source":"print(\"\\nAudit Report\")"},{"dal_engine_uid":"a184f30f-4f3b-40fc-a6f0-b1712e08eeb3","_behaviorId":"HandBookToUser","_participants":[],"_uid":"6089d6a7-23e0-4a01-8d02-78252f198fb7","_start_line":110,"_end_line":110,"_source":"print(\"------------\")"},{"dal_engine_uid":