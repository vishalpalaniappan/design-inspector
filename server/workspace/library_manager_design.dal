a27c49d-3de2-4a2f-9ac7-ab43f63dabca"],"_invalidWorldState":false,"_name":"GetFirstLetterOfBookName","_description":""},"_goToBehaviorIds":["AddBookToShelf","CreateSlotOnBookShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"b28fa95d-2793-44ef-906b-0aa1e92cb37b","type":5,"_behavior":{"dal_engine_uid":"422f5ab3-f62a-4f26-b859-6f0c7802705f","_type":1,"_participants":[{"dal_engine_uid":"1696bcf6-0d99-4bc1-8eee-6f8109731365","_type":3,"_invariants":[{"dal_engine_uid":"0d0b0881-b7b5-4ceb-84b3-d7b2c7bb501b","type":2,"invariantViolated":null,"invariantType":{"type":"min_length","label":"Minimum Length","properties":{"keys":{"label":"Key(s) of value in object","type":"Array","required":true,"value":["value","name"]},"minLength":{"label":"Minimum Length","type":"string","required":true,"value":"1"}},"invariantViolated":null},"traceId":null,"_name":"Book Name Length","_description":"Book name must have a minimum length of 1.","value":null}],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":["2e2c563c-bdf0-4a8f-a33e-ce1f7d2f4dfb","44e3472e-5f99-4240-b475-718a516dbf41","7f1863d0-98f2-48f3-9a86-5cace1481a56","f014b843-acc6-4974-801a-9b3ca7f9b1bc"],"_invalidWorldState":false,"_name":"AcceptBook","_description":"Accepts a book with a name and genre."},"_goToBehaviorIds":["PlaceBookInBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"461bb544-bf40-4ad0-902d-3bc19354dc0f","type":5,"_behavior":{"dal_engine_uid":"d43f941a-f4dc-4f85-9b3b-a8a59c880bfe","_type":1,"_participants":[{"dal_engine_uid":"57ec5c54-e0b5-486f-8041-45162b432ac3","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Basket","_description":""},{"dal_engine_uid":"26a17f69-c46b-4e70-9de1-e54022f577d1","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":""}],"_abstractionIds":["00249929-781a-4553-9b7b-7b5fd038b2c3"],"_invalidWorldState":false,"_name":"PlaceBookInBasket","_description":"Place book in basket."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"c9ff3bbe-330c-4a43-bda0-4f16ab5fdfcf","type":5,"_behavior":{"dal_engine_uid":"c2166025-5575-47ba-b940-321307a8a775","_type":1,"_participants":[],"_abstractionIds":["148a6702-f8d0-4e1e-8cc1-ff5a5913d2e4"],"_invalidWorldState":false,"_name":"GenerateAuditReport","_description":"Generate a report with all the books in the basket and all the books on the shelf."},"_goToBehaviorIds":["HandBookToUser"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"4cdd76aa-9a2b-4541-977d-c02fce29b2f5","type":5,"_behavior":{"dal_engine_uid":"22b47b48-051d-4bb4-b999-49327587ed9a","_type":1,"_participants":[],"_abstractionIds":["5f9dc02f-42d0-47f5-ad7d-66b5f8806a3d","4041dfca-3ec5-4d78-8845-c3e99bcdedb0","8886c96e-38ea-4f20-b1c3-43597ebfd583"],"_invalidWorldState":false,"_name":"HandBookToUser","_description":"Give the report to the user."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false}],"name":"AcceptLoop","description":""}},"implementation":{"_sourceFiles":[{"name":"library_manager.py","path":"library_manager.py","content":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","updatedContent":"from typing import Optional\r\n\r\nbasket: list[dict] = []\r\nbook_shelf: dict[str, list[dict]] = {}\r\n\r\n\r\ndef PresentMenuAndAcceptUserChoice() -> str:\r\n    \"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"\r\n    print(\"\\nMenu\")\r\n    print(\"----\")\r\n    print(\"a: Add book to basket\")\r\n    print(\"p: Place books on shelf\")\r\n    print(\"d: Audit library\")\r\n    print(\"Any other key: Exit\")\r\n    response = input(\"Choice: \").strip().lower()\r\n    return response\r\n\r\n\r\ndef GetBookFromBasket() -> Optional[dict]:\r\n    \"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"\r\n    if not basket:\r\n        return None\r\n    return basket.pop(0)\r\n\r\n\r\ndef GetFirstLetterOfBookName(book: dict) -> str:\r\n    \"\"\"\r\n    Gets the first letter of the book name.\r\n    Participant:\r\n    - FirstLetter\r\n    \"\"\"\r\n    return book[\"name\"][0]\r\n\r\n\r\ndef CreateSlotOnBookShelf(first_letter: str) -> None:\r\n    \"\"\"\r\n    Creates a slot on the bookshelf.\r\n    Participant:\r\n    - BookShelf\r\n    \"\"\"\r\n    if first_letter not in book_shelf:\r\n        book_shelf[first_letter] = []\r\n\r\n\r\ndef AddBookToShelf(book: dict, first_letter: str) -> None:\r\n    \"\"\"\r\n    Adds a book to the bookshelf.\r\n    Participants:\r\n    - Book\r\n    - BookShelf\r\n    \"\"\"\r\n    book_shelf[first_letter].append(book)\r\n\r\n\r\ndef AcceptBook() -> dict:\r\n    \"\"\"\r\n    Accepts a book with a name and genre.\r\n\r\n    Participant:\r\n    - Book\r\n    \"\"\"\r\n    name = input(\"Book name: \")\r\n    genre = input(\"Book genre: \")\r\n\r\n    book = {\r\n        \"name\": name,\r\n        \"genre\": genre,\r\n    }\r\n\r\n    return book\r\n\r\n\r\ndef PlaceBookInBasket(book: dict) -> None:\r\n    \"\"\"\r\n    Places the book in the basket.\r\n    Participants:\r\n    - Basket\r\n    - Book\r\n    \"\"\"\r\n    basket.append(book)\r\n\r\n\r\ndef GenerateAuditReport() -> dict:\r\n    \"\"\"\r\n    Generates the audit report.\r\n    Participant:\r\n    - AuditReport\r\n    \"\"\"\r\n    return {\r\n        \"basket\": list(basket),\r\n        \"book_shelf\": {key: list(value) for key, value in book_shelf.items()},\r\n    }\r\n\r\n\r\ndef HandBookToUser(item: dict) -> None:\r\n    \"\"\"\r\n    Hands the result to the user.\r\n\r\n    The design routes GenerateAuditReport -> HandBookToUser,\r\n    so this function displays the produced result to the user.\r\n    \"\"\"\r\n    print(\"\\nAudit Report\")\r\n    print(\"------------\")\r\n    print(item)\r\n\r\n\r\ndef ExecutePlaceBooksOnShelfPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToPlaceBooksOnShelf\r\n      -> GetBookFromBasket\r\n      -> GetFirstLetterOfBookName\r\n      -> CreateSlotOnBookShelf / AddBookToShelf\r\n      -> GetBookFromBasket\r\n    \"\"\"\r\n    while True:\r\n        book = GetBookFromBasket()\r\n        if book is None:\r\n            break\r\n\r\n        first_letter = GetFirstLetterOfBookName(book)\r\n\r\n        if first_letter not in book_shelf:\r\n            CreateSlotOnBookShelf(first_letter)\r\n\r\n        AddBookToShelf(book, first_letter)\r\n\r\n\r\ndef ExecuteAddBookToBasketPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAddBookToBasket\r\n      -> AcceptBook\r\n      -> PlaceBookInBasket\r\n    \"\"\"\r\n    book = AcceptBook()\r\n    PlaceBookInBasket(book)\r\n\r\n\r\ndef ExecuteAuditLibraryPath() -> None:\r\n    \"\"\"\r\n    Realizes:\r\n\r\n    AcceptChoiceToAuditLibrary\r\n      -> GenerateAuditReport\r\n      -> HandBookToUser\r\n    \"\"\"\r\n    audit_report = GenerateAuditReport()\r\n    HandBookToUser(audit_report)\r\n\r\n\r\ndef AcceptLoop() -> None:\r\n    \"\"\"\r\n    Realizes the AcceptLoop graph.\r\n\r\n    The design shows the menu behavior as a fork to one of the three paths,\r\n    so this loop repeatedly presents the menu and dispatches accordingly.\r\n    \"\"\"\r\n    while True:\r\n        response = PresentMenuAndAcceptUserChoice()\r\n\r\n        if response == \"p\":\r\n            ExecutePlaceBooksOnShelfPath()\r\n\r\n        elif response == \"d\":\r\n            ExecuteAuditLibraryPath()\r\n\r\n        elif response == \"a\":\r\n            ExecuteAddBookToBasketPath()\r\n\r\n        else:\r\n            break\r\n\r\n\r\nif __name__ == \"__main__\":\r\n    AcceptLoop()","type":"file","uid":"4d3ba263-07a8-4a0f-aed8-0245575cf4b4","level":0,"collapsed":false,"isDirty":false,"mapping":[{"type":"ImportFrom","source_path":null,"uid":"eec3d01c-8e1b-48dc-bdd9-909f4693eb6d","start_line":1,"end_line":1,"source":"from typing import Optional","isMappedCurrent":false,"isMappedOther":false},{"type":"AnnAssign","source_path":null,"uid":"9e6d45be-a764-47c2-b98e-6e587f9eeb9a","start_line":3,"end_line":3,"source":"basket: list[dict] = []","isMappedCurrent":false,"isMappedOther":false},{"type":"AnnAssign","source_path":null,"uid":"f91368ff-09c8-45e5-8497-6120fa302f32","start_line":4,"end_line":4,"source":"book_shelf: dict[str, list[dict]] = {}","isMappedCurrent":false,"isMappedOther":false},{"type":"Expr","source_path":null,"uid":"72dafff2-bf63-40e7-b043-bf50a29d95e5","start_line":8,"end_line":10,"source":"\"\"\"\r\n    Presents the menu to the user and accepts their choice.\r\n    \"\"\"","isMappedCurrent":false,"isMappedOther":false},{"type":"Expr","source_path":null,"uid":"75edef15-71a5-4a6f-900c-e28281b094ab","start_line":11,"end_line":11,"source":"print(\"\\nMenu\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"9a211a07-a1de-47f8-8a2d-e48362d9aa6f","start_line":12,"end_line":12,"source":"print(\"----\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"044be020-7c5f-489b-bef0-313277c3bbb0","start_line":13,"end_line":13,"source":"print(\"a: Add book to basket\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"bda3f165-e0e0-4f51-abd2-cc869062bd32","start_line":14,"end_line":14,"source":"print(\"p: Place books on shelf\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"72b7c255-0713-470a-a6e3-4bad5537ccb4","start_line":15,"end_line":15,"source":"print(\"d: Audit library\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"18326fd8-4857-4f53-8dc1-c2f3d9213b54","start_line":16,"end_line":16,"source":"print(\"Any other key: Exit\")","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Assign","source_path":null,"uid":"990ebcff-b50c-47fc-b8da-dace79c33c77","start_line":17,"end_line":17,"source":"response = input(\"Choice: \").strip().lower()","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Return","source_path":null,"uid":"6f0ab5b9-30b0-4e17-9e59-43e93a90b405","start_line":18,"end_line":18,"source":"return response","isMappedCurrent":false,"isMappedOther":true,"behaviorId":"PresentMenuAndAcceptUserChoice"},{"type":"Expr","source_path":null,"uid":"6bf8d122-1f58-490a-ba1c-b6a63b15a288","start_line":22,"end_line":27,"source":"\"\"\"\r\n    Gets a book from the basket.\r\n    Participants:\r\n    - Book\r\n    - Basket\r\n    \"\"\"","isMappedCurrent":false,"isMappedOther":false},{"type":"If","source_path":null,"uid":"9f820832-2c06-4d7b-8348-0324b824a896","start_line":28,"end_line":28,"source":["    if not basket:"],"isMappedCurrent":true,"isMappedOther":false,"behaviorId":"GetBookFromBasket"},{"type":"Return","source_path":null,"uid":"83d00f12-03ca-47b2-8cef-4ef00a7eac2a","start_line":29,"end_line":29,"source":"return None","isMappedCurrent":true,"isMappedOther":false,"behaviorId":"GetBookFromBasket"},{"type":"Return","source_path":null,"uid":"20888fee-776c-458c-a7b3-5e87ef1d4405","start_line":30,"end_line":30,"source":"return basket.pop(0)","isMappedCurrent":true,"isMappedOther":false,"behaviorId":"GetBookFromBasket"},{"type":"Expr","source_path":null,"uid":"e716d41e-2f89-45fc-9239-a39be3f5c222","start