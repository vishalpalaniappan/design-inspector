{"name":"Library Manager","description":"","graphs":{"_graphs":{"AcceptLoop":{"dal_engine_uid":"4e18f6a0-f59a-405f-9c80-14837df14b87","type":4,"nodes":[{"dal_engine_uid":"e852a920-8e44-429e-a46e-9f8ee58f3969","type":5,"_behavior":{"dal_engine_uid":"01e95246-bd6d-4a26-812c-e2b0a8ccb2c4","_type":1,"_participants":[{"dal_engine_uid":"a51044c4-f6a7-4855-b19b-d26dba0742e3","_type":3,"_invariants":[],"_abstractionId":{"abstractionId":"990ebcff-b50c-47fc-b8da-dace79c33c77","variableName":"respones"},"_invariantViolated":false,"_name":"test","_description":""}],"_abstractionIds":["75edef15-71a5-4a6f-900c-e28281b094ab","9a211a07-a1de-47f8-8a2d-e48362d9aa6f","044be020-7c5f-489b-bef0-313277c3bbb0","bda3f165-e0e0-4f51-abd2-cc869062bd32","72b7c255-0713-470a-a6e3-4bad5537ccb4","18326fd8-4857-4f53-8dc1-c2f3d9213b54","990ebcff-b50c-47fc-b8da-dace79c33c77","6f0ab5b9-30b0-4e17-9e59-43e93a90b405"],"_invalidWorldState":false,"_name":"PresentMenuAndAcceptUserChoice","_description":"Presents the menu to the user and accepts their choice."},"_goToBehaviorIds":["GetBookFromBasket","AcceptBook","GenerateAuditReport"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"a5e94a16-f6b3-4d25-a053-173b903d012d","type":5,"_behavior":{"dal_engine_uid":"c809dc9e-e549-439a-8f9c-daf9032a63b8","_type":1,"_participants":[],"_abstractionIds":["9f820832-2c06-4d7b-8348-0324b824a896","83d00f12-03ca-47b2-8cef-4ef00a7eac2a","20888fee-776c-458c-a7b3-5e87ef1d4405"],"_invalidWorldState":false,"_name":"GetBookFromBasket","_description":""},"_goToBehaviorIds":["GetFirstLetterOfBookName"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"e2726e2f-95b2-4f27-916c-3073d641f6de","type":5,"_behavior":{"dal_engine_uid":"97d6fc84-27c3-4d59-aea9-3a19de923ca7","_type":1,"_participants":[{"dal_engine_uid":"b048d871-4aec-404c-958c-63c80edb5043","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"BookShelf","_description":"Book shelf to place books in."}],"_abstractionIds":["40